 inc MASTODON-CONFIG-NORMAL-4-MAMODEL .
 ---- raceboat model includes
 inc MASTODON-CLIENT-CONFIG-CP2-SCENARIO-8-NEW-MAMODEL .
 inc MASTODON-SERVER-CONFIG-CP2-SCENARIO-8-NEW-MAMODEL .
eq monitorQueryLog? = true .

eq noiseMin(msg:Msg) = 0.001 .
eq exeDone(< mon:Address :  WMonitor | attrs:AttributeSet, doneFlag: true > conf:Config) = true .
eq raceBoatMastodonClients = (alice-raceboat-client-mas-client ;; user-bob-raceboat-server-mas-client) .
eq content-matches(C:Content) = isHttpReq(C:Content) .
eq add-to-sent(tm(tt:Float,to addr0:Address from addr1:Address : c:Content)) = tm(tt:Float,to public-dns from addr1:Address : query(0, 'mastodon . 'pwnd . 'com . root, a)) .
eq fileSize = 1000 .
eq packetSize = 530 .
eq packetOverhead = 33 .
eq maxMinimiseCount = 0 .
eq maxFragmentTx = 20 .
eq maxUpFragmentLen = 200 .
eq maxDownFragmentLen = 510 .
eq maxPacketSize = 530 .
eq pacingTimeoutDelay = 0.01 .
eq pacingTimeoutDelayMax = 0.01 .
eq ackTimeoutDelay = 1.0 .
eq pingInterval = 1.0 .
eq initialPingDelay = 1.0 .
eq receiveToPingDelay = 0.001 .
