set clear rules off .
set print attribute off .
set show advisories off .

mod HCS_TEST is
 inc DNS .
 inc USER-ACTION-ACTOR .
 inc DNS-TGEN .
 inc IODINE_DNS . --- + TEST-HELPERS .
 inc ROUTER .
 inc MASTODON .
 inc MAS-TGEN .
 inc ADVERSARY-OBSERVER .
 inc CP2_APP .
inc HTTP-OVERHEAD .
 ---- tgen model includes
 inc DNS-CONFIG-NORMAL-1-MAMODEL .
 inc DNS-CONFIG-NORMAL-2-MAMODEL .
 inc DNS-CONFIG-NORMAL-3-MAMODEL .
 inc DNS-CONFIG-NORMAL-4-MAMODEL .
