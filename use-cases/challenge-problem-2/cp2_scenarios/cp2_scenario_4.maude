set clear rules off .
set print attribute off .
set show advisories off .

mod HCS_TEST is
 inc DNS .
 inc USER-ACTION-ACTOR .
 inc DNS-TGEN .
 inc IODINE_DNS . --- + TEST-HELPERS .
 inc ROUTER .
 inc MASTODON .
 inc MAS-TGEN .
 inc ADVERSARY-OBSERVER .
 inc CP2_APP .
inc ENC-DEC .
inc CONTENT-MANAGER-CLIENT .
inc CONTENT-MANAGER-SERVER .
inc HTTP-OVERHEAD .
 ---- tgen model includes
 inc DNS-CONFIG-SLOW-1-MAMODEL .
 inc DNS-CONFIG-SLOW-2-MAMODEL .
 inc DNS-CONFIG-SLOW-3-MAMODEL .
 inc DNS-CONFIG-SLOW-4-MAMODEL .
 inc MASTODON-CONFIG-LURKER-1-MAMODEL .
 inc MASTODON-CONFIG-LURKER-2-MAMODEL .
 inc MASTODON-CONFIG-LURKER-3-MAMODEL .
 inc MASTODON-CONFIG-LURKER-4-MAMODEL .
 ---- raceboat model includes
 inc MASTODON-CLIENT-CONFIG-CP2-SCENARIO-4-NEW-MAMODEL .
 inc MASTODON-SERVER-CONFIG-CP2-SCENARIO-4-NEW-MAMODEL .
eq monitorQueryLog? = true .

eq encOH(fsize:Nat,ksize:Nat) = (if ksize:Nat < fsize:Nat then 0 else ksize:Nat + (- fsize:Nat) fi) .
eq noiseMin(msg:Msg) = 0.001 .
eq exeDone(< mon:Address :  WMonitor | attrs:AttributeSet, doneFlag: true > conf:Config) = true .
eq raceBoatMastodonClients = (alice-raceboat-client-mas-client ;; user-bob-raceboat-server-mas-client) .
eq content-matches(C:Content) = isHttpReq(C:Content) .
eq add-to-sent(tm(tt:Float,to addr0:Address from alice-raceboat-client-mas-client : c:Content)) = tm(tt:Float,to X(public-dns) from alice-raceboat-client-mas-client : query(0, 'mastodon . 'pwnd . 'com . root, a)) ; tm(tt:Float,to X(public-dns) from alice-raceboat-client-mas-client : query(0, 'mastodon . 'pwnd . 'com . root, a)) .
eq add-to-sent(tm(tt:Float,to addr0:Address from Z(i:Nat, alice-raceboat-client-mas-client) : c:Content)) = tm(tt:Float,to public-dns from Z(i:Nat, alice-raceboat-client-mas-client) : query(0, 'mastodon . 'pwnd . 'com . root, a)) .
eq fileSize = 1000 .
eq packetSize = 530 .
eq packetOverhead = 33 .
eq maxMinimiseCount = 0 .
eq maxFragmentTx = 20 .
eq maxUpFragmentLen = 200 .
eq maxDownFragmentLen = 510 .
eq maxPacketSize = 530 .
eq pacingTimeoutDelay = 0.01 .
eq pacingTimeoutDelayMax = 0.01 .
eq ackTimeoutDelay = 1.0 .
eq pingInterval = 1.0 .
eq initialPingDelay = 1.0 .
eq receiveToPingDelay = 0.001 .
eq slimit = 6000.0 .

