--- Initial configuration
op initState : -> Config .
eq initState =
  --- Client start messages
  --- Clients
  --- Resolvers
  mkResolver(public-dns, resolverCache, sb)
  --- Nameservers
  mkNameServer(root-dns, (zone), nullAddr)
  mkNameServer(tld-dns, (zoneCom), nullAddr)
  mkNameServer(auth-dns, (zoneInternetCom), nullAddr)
  mkNameServer(corporate-dns, (zoneCorporateCom), X(public-dns))
  --- standalone actors
  rCtr(1)
  mkRouter(router)
