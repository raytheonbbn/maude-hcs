//  from pwnd-cp3/src/adversary/configs/thresholds.json
//  "dns_query_rate": 2.5,
//  "dns_query_size_mean": 2.5,
//  "dns_response_size_mean": 2.5,
//  "tcp_upload_rate": 3.5,
//  "tcp_download_rate": 3.5,
//  "tcp_upload_download_ratio": 5.0,
//  "tcp_outgoing_packet_rate": 3.5,
//  "tcp_incoming_packet_rate": 3.5,
//  "tcp_packet_upload_download_ratio": 5.0,
//  "packet_size_std_dev": 4.0,
//  "packet_size_mean": 3.0,
//  "packet_interarrival_mean": 3.0,
//  "direction_change_count": 4.0,
//  "active_flow_count": 2.5,
//  "tcp_new_conn_count": 3.5

// getToD (vantage_point, feature, C:Config, Tstart, Tend, window_size (seconds), bin_size (seconds), threshold) 
ToDDnsQueryRate() = s.rval("getToD (IXP, dnsQueryRate, C, Tstart, Tend, 60.0, 10.0, dns_query_rate)");
ToDDnsQuerySize() = s.rval("getToD (IXP, dnsQuerySize, C, Tstart, Tend, 60.0, 10.0, dns_query_size_mean)");
ToDDnsRespSize() = s.rval("getToD (IXP, dnsRespSize, C, Tstart, Tend, 60.0, 10.0, dns_response_size_mean)");
ToDTcpUpRate() = s.rval("getToD (IXP, tcpUpRate, C, Tstart, Tend, 60.0, 10.0, tcp_upload_rate)");
ToDTcpDownRate() = s.rval("getToD (IXP, tcpDownRate, C, Tstart, Tend, 60.0, 10.0, tcp_download_rate)");
ToDTcpUpToDownRate() = s.rval("getToD (IXP, tcpUpToDownRate, C, Tstart, Tend, 60.0, 10.0, tcp_upload_download_ratio)");
ToDTcpOutPktRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_outgoing_packet_rate)");
ToDTcpInPktRate() = s.rval("getToD (IXP, tcpInPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_incoming_packet_rate)");
ToDTcpOutToInPktRate() = s.rval("getToD (IXP, tcpOutToInPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_packet_upload_download_ratio)");
ToDTcpPktSizeStdDev() = s.rval("getToD (IXP, tcpPktSizeStdDev, C, Tstart, Tend, 60.0, 10.0, packet_size_std_dev)");
ToDTcpPktSize() = s.rval("getToD (IXP, tcpPktSize, C, Tstart, Tend, 60.0, 10.0, packet_size_mean)");
ToDTcpPktInterarrival() = s.rval("getToD (IXP, tcpPktInterarrival, C, Tstart, Tend, 60.0, 10.0, packet_interarrival_mean)");
ToDTcpDirectionChange() = s.rval("getToD (IXP, tcpDirectionChange, C, Tstart, Tend, 60.0, 10.0, direction_change_count)");
ToDTcpActiveFlow() = s.rval("getToD (IXP, tcpActiveFlow, C, Tstart, Tend, 60.0, 10.0, active_flow_count)");
ToDTcpNewCnx() = s.rval("getToD (IXP, tcpNewCnx, C, Tstart, Tend, 60.0, 10.0, tcp_new_conn_count)");

