//////////////
// Performance
//////////////

Latency0() = s.rval("getMinLatency(getMonitor(C), 0.0, 1000.0)");
Latency25() = s.rval("getPercentileLatency(getMonitor(C), 0.0, 1000.0, 25)");
Latency50() = s.rval("getAvgLatency(getMonitor(C), 0.0, 1000.0)");
Latency75() = s.rval("getPercentileLatency(getMonitor(C), 0.0, 1000.0, 75)");
Latency100() = s.rval("getMaxLatency(getMonitor(C), 0.0, 1000.0)");
Goodput() = s.rval("getGoodput(getMonitor(C), 0.0, 1000.0)");

eval E[Latency0()] with delta = 2 ;
eval E[Latency25()] with delta = 2 ;
eval E[Latency50()] with delta = 2 ;
eval E[Latency75()] with delta = 2 ;
eval E[Latency100()] with delta = 2 ;
eval E[Goodput()] with delta = 2 ;

///////////////
// Integrity 
///////////////

Integrity() = s.rval("getSystemIntegrity(getMonitor(C), getIrcSrv(C), 0.0, 1000.0)");

eval E[Integrity()] ;

///////////////
// Availabolity
///////////////

MTBF() = s.rval("getMTBF(getMonitor(C), 16.0, 0.0, 1000.0)");

eval E[MTBF()] with delta = 2 ;

