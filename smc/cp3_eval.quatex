// getToD (vantage_point, feature, C:Config, Tstart, Tend, window_size (seconds), bin_size (seconds), threshold) 
ToDDnsQueryRate() = s.rval("getToD (IXP, dnsQueryRate, C, Tstart, Tend, 60.0, 10.0, dns_query_rate)");
ToDDnsQuerySize() = s.rval("getToD (IXP, dnsQuerySize, C, Tstart, Tend, 60.0, 10.0, dns_query_size_mean)");
ToDDnsRespSize() = s.rval("getToD (IXP, dnsRespSize, C, Tstart, Tend, 60.0, 10.0, dns_response_size_mean)");
ToDTcpUpRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_upload_rate)");
ToDTcpDownRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_download_rate)");
ToDTcpUpToDownRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_upload_download_ratio)");
ToDTcpOutPktRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_outgoing_packet_rate)");
ToDTcpInPktRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_incoming_packet_rate)");
ToDTcpOutToInPktRate() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_packet_upload_download_ratio)");
ToDTcpPktSizeStdDev() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, packet_size_std_dev)");
ToDTcpPktSize() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, packet_size_mean)");
ToDTcpPktInterarrival() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, packet_interarrival_mean)");
ToDTcpDirectionChange() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, direction_change_count)");
ToDTcpActiveFlow() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, active_flow_count)");
ToDTcpNewCnx() = s.rval("getToD (IXP, tcpOutPktRate, C, Tstart, Tend, 60.0, 10.0, tcp_new_conn_count)");

