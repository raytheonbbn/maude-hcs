                else s.rval("getToDCumulativeResponsePostNAT(C,80000) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC7() = if (s.rval("getToDCumulativeHttpConnectionPreNAT(C,22)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpConnectionPreNAT(C,22) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC8() = if (s.rval("getToDCumulativeHttpConnectionPostNAT(C,34)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpConnectionPostNAT(C,34) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC9() = if (s.rval("getToDCumulativeHttpUploadPreNAT(C,6500000)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpUploadPreNAT(C,6500000) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC10() = if (s.rval("getToDCumulativeHttpUploadPostNAT(C,29379348)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpUploadPostNAT(C,29379348) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA1() = if (s.rval("getToD(C,60.0,60.0,10.0,1.04,2)") == 0.0) then discard
                else s.rval("getToD(C,60.0,60.0,10.0,1.04,2) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA2() = if (s.rval("getToDAvgQuerySize(C,60.0,60.0,10.0,1.01,2)") == 0.0) then discard
                else s.rval("getToDAvgQuerySize(C,60.0,60.0,10.0,1.01,2) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA3() = if (s.rval("getToDAvgResponseSize(C,60.0,60.0,10.0,1.01,2)") == 0.0) then discard
                else s.rval("getToDAvgResponseSize(C,60.0,60.0,10.0,1.01,2) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA4() = if (s.rval("getToDAvgUploadRate(C,60.0,60.0,10.0,1.04,2)") == 0.0) then discard
                else s.rval("getToDAvgUploadRate(C,60.0,60.0,10.0,1.04,2) - getExfilStartTime(getMonitor(C))") fi;

// Probability of detection
PoDC1() = s.rval("getPoDCumulativeNQueryPreNAT(C,240)");
PoDC2() = s.rval("getPoDCumulativeNQueryPostNAT(C,1220)");
PoDC3() = s.rval("getPoDCumulativeQuerySizePreNAT(C,12000)");
PoDC4() = s.rval("getPoDCumulativeQuerySizePostNAT(C,74676)");
