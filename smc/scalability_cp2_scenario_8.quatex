                else s.rval("getToDCumulativeResponsePostNAT(C,80000) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC7() = if (s.rval("getToDCumulativeHttpConnectionPreNAT(C,32)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpConnectionPreNAT(C,32) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC8() = if (s.rval("getToDCumulativeHttpConnectionPostNAT(C,44)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpConnectionPostNAT(C,44) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC9() = if (s.rval("getToDCumulativeHttpUploadPreNAT(C,8000000)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpUploadPreNAT(C,8000000) - getExfilStartTime(getMonitor(C))") fi;
OpDurationC10() = if (s.rval("getToDCumulativeHttpUploadPostNAT(C,27000000)") == 0.0) then discard
                else s.rval("getToDCumulativeHttpUploadPostNAT(C,27000000) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA1() = if (s.rval("getToD(C,60.0,60.0,10.0,1.04,3)") == 0.0) then discard
                else s.rval("getToD(C,60.0,60.0,10.0,1.04,3) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA2() = if (s.rval("getToDAvgQuerySize(C,60.0,60.0,10.0,1.01,3)") == 0.0) then discard
                else s.rval("getToDAvgQuerySize(C,60.0,60.0,10.0,1.01,3) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA3() = if (s.rval("getToDAvgResponseSize(C,60.0,60.0,10.0,1.01,3)") == 0.0) then discard
                else s.rval("getToDAvgResponseSize(C,60.0,60.0,10.0,1.01,3) - getExfilStartTime(getMonitor(C))") fi;
OpDurationMA4() = if (s.rval("getToDAvgUploadRate(C,60.0,60.0,10.0,1.04,3)") == 0.0) then discard
                else s.rval("getToDAvgUploadRate(C,60.0,60.0,10.0,1.04,3) - getExfilStartTime(getMonitor(C))") fi;

// Probability of detection
PoDC1() = s.rval("getPoDCumulativeNQueryPreNAT(C,255)");
PoDC2() = s.rval("getPoDCumulativeNQueryPostNAT(C,1257)");
PoDC3() = s.rval("getPoDCumulativeQuerySizePreNAT(C,12000)");
PoDC4() = s.rval("getPoDCumulativeQuerySizePostNAT(C,77325)");
