PoDC6() = s.rval("getPoDCumulativeResponsePostNAT(C,80000)");
PoDC7() = s.rval("getPoDCumulativeHttpConnectionPreNAT(C,32)");
PoDC8() = s.rval("getPoDCumulativeHttpConnectionPostNAT(C,44)");
PoDC9() = s.rval("getPoDCumulativeHttpUploadPreNAT(C,8000000)");
PoDC10() = s.rval("getPoDCumulativeHttpUploadPostNAT(C,27000000)");
PoDMA1() = s.rval("getPoDAvgQPS(C,60.0,60.0,10.0,1.04,3)");
PoDMA2() = s.rval("getPoDAvgQPS(C,60.0,60.0,10.0,1.01,3)");
