// Scalability
ExfilFilesC2() = if (s.rval("getToDCumulativeNQueryPostNAT(C,100)") == 0.0) then discard 
                  else s.rval("getLatency(getMonitor(C))") fi ; 
//                else s.rval("getExfilFiles(getMonitor(C), s.rval("getToDCumulativeNQueryPostNAT(C,100)")) ") fi;
