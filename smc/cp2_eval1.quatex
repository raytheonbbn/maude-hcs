eval E[ToDCumulativeHttpConnectionPostNAT()];
//eval E[ToDCumulativeHttpUploadPreNAT()];
//eval E[ToDCumulativeHttpUploadPostNAT()];

// Moving Average Adversary Profiles
eval E[ToDAvgQPS()];
