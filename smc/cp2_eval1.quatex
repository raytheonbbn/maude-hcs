import "latency.quatex";
import "goodput.quatex";
import "adversaryX.quatex";

// Performance
eval E[Latency()] with delta = 2 ;
eval E[Goodput()] with delta = 2 ;

// Cumulative Adversary Profiles
//eval E[ToDCumulativeNQueryPreNAT()];
eval E[ToDCumulativeNQueryPostNAT()] ;
