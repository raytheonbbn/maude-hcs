---- < cmcA : CMClient | bHashTagCtr: 1, pendingFiles: nilBS, currentFrags: nilBS, pendingHashTags: nilBS, numBHashTags: 3, edAddress: edA, mcAddress: mcA, w4c: null, replyTo: null >
****[0.0, to umA from cmcA : actionR("ok"), 0]



---- crl [rbc-rcv-capR] : after rcvfile/rcv media action
eq McapR = {2.0,(to cmcA from edA :  capR(50) )} .
---- w4c: (to edA from cmcA : capQ(100)) 
---- pendingFiles: (efile(id,n,j,k); efilel), 
---- currentFrags: efrag(efile,tot,ix,n0),  
eq MencR0 = {3.0,(to cmcA from edA :  encR(IM00) )} .

---- rew CMCfm McapR .   #
eq CMCfmc = 
< cmcA : CMClient |
    bHashTagCtr: 0,
    pendingFiles: efile(0, 20, 0, 20),
    currentFrags: efrag(efile(0, 20, 0, 20), 20, 1, 0),
    pendingHashTags: hashTag("man"),
    numPendingImages: 1,
    encodedImages: nilBS,
    numBHashTags: 5,
    edAddress: edA,
    mcAddress: mcA,
    w4c: (to edA from cmcA : encQ(efrag(efile(0, 20, 0, 20), 20, 0, 20))),
    replyTo: (to cmcA from umA : actionQ("type" |-> js("media"))),
    hashtagMap: (0 |-> "meow", 1 |-> "cat", 2 |-> "dog", 3 |-> "orange", 4 |-> "purple") > 
.
**** [0.0, to edA from cmcA : encQ(efrag(efile(0, 20, 0, 20), 20, 0, 20)), 0]


---- rew CMCfmc MencR0 .   #   --- old parameters
eq CMCfmce =
< cmcA : CMClient |
  bHashTagCtr: 0,
  pendingFiles: nilBS,
  currentFrags: nilBS,
  pendingHashTags: nilBS,
    numPendingImages: 1,
    encodedImages: nilBS,
  numBHashTags: 5,
  edAddress: edA,
  mcAddress: mcA,
  w4c: (to mcA from cmcA : tootQ(hashTag("man"), encode(image(0, 500, 50), efrag(efile(0, 20, 0, 20), 20, 0, 20), 1, 4, 1/10))),
  replyTo: (to cmcA from umA : actionQ("type" |-> js( "media"))),
  hashtagMap: (0 |-> "meow", 1 |-> "cat", 2 |-> "dog", 3 |-> "orange", 4 |-> "purple") > 
.

**** [0.0, to mcA from cmcA : PostStatus("hashtag is #man", makeMediaFile( makeMediaFilename(encode(image(0, 500, 50), efrag(efile(0, 20, 0, 20), 20, 0, 20), 1, 4, 1/10)), 500, encode(image(0, 500, 50), efrag(efile(0, 20, 0, 20), 20, 0, 20), 1, 4, 1/10))), 0]
 
---- rew CMCfmce MrequestR .  #
---- CMC  [0.0, to umA from cmcA : actionR("ok"), 0]

---- crl [rbc-rcv-encR] :
eq MencR = {3.0,(to cmcA from edA :  encR(IM0) )} .
---- w4c: (to edAddr from cmcAddr : encQ(efrag)),
---- pendingFiles: nilBS   or
----     currentFrags: efrag(efile,tot,ix,n0),  
----     pendingFiles: (efile ; efilel), 

---- rew CMCm  MencR .  --> CMCme   #
eq CMCme =
< cmcA : CMClient |
  bHashTagCtr: 1,
  pendingFiles: nilBS,
  currentFrags: nilBS,
  pendingHashTags: nilBS,
  numPendingImages: 1,
  encodedImages: image(0, 500, 50),
  numBHashTags: 5,
  edAddress: edA,
  mcAddress: mcA,
  w4c: (to mcA from cmcA : tootQ(hashTag("meow"), image(0, 500, 50))),
  replyTo: (to cmcA from umA : actionQ("type" |-> js("media"))),
  hashtagMap: (0 |-> "meow", 1 |-> "cat", 2 |-> "dog", 3 |-> "orange", 4 |-> "purple") > 
.

**** [0.0, to mcA from cmcA : PostStatus( "hashtag is #meow", makeMediaFile(makeMediaFilename(image(0, 500, 50)), 500, image(0, 500, 50))), 0]

---- rew CMCme MrequestR .   #
---- CMC
---- [0.0, to umA from cmcA : actionR("ok"), 0]

endm  
eof



--------------------------------------------------
set print attribute on .
red CMC .


rew CMC Mfile .
rew CMC Mmedia .
rew CMC Mdown .

rew CMCd MfetchR .
rew CMCm  MencR .
rew CMCme MtootR .

rew CMCf Mmedia .
rew CMCfm McapR .
rew CMCfmc MencR0 .

rew CMCfmce MtootR .

