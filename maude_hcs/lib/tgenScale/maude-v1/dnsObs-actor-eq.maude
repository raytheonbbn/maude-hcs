red run(iC, 100.) . 

result Config: rCtr(91)
{3.7081706743084254e+1 | nil} 
< dnsQA : DNSQgen-Eq | qnameBase: 'internet . 'com . root, lenNameDB: 1000, dnsClient: dnsOA, numQ: 0, w4q: null, replyTo: null > 
< dnsOA : DNSObserver | rsvAddr: rsvA, ctr: 7 > 
< advA : Adversary | dnsQuery: (tm(1.1119393019471318e-4, to rsvA from dnsOA : query(0, label(673) . 'internet . 'com . root, a)) ; tm( 1.7807700070642149e+1, to rsvA from dnsOA : query(1, label(474) . 'internet . 'com . root, a)) ; tm(1.7851352732585806e+1, to rsvA from dnsOA : query(2, label(632) . 'internet . 'com . root, a)) ; tm( 1.7901684764322145e+1, to rsvA from dnsOA : query(3, label(645) . 'internet . 'com . root, a)) ; tm(1.7945800897386423e+1, to rsvA from dnsOA : query(4, label(521) . 'internet . 'com . root, a)) ; tm( 1.8031758340050448e+1, to rsvA from dnsOA : query(5, label(490) . 'internet . 'com . root, a)) ; tm(1.8099425817079833e+1, to rsvA from dnsOA : query(6, label(633) . 'internet . 'com . root, a))), dnsResponse: (tm(8.8993194073582457e-2, to dnsOA from rsvA : response(0, label(673) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm( 1.7851352544687824e+1, to dnsOA from rsvA : response(1, label(474) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm(1.7901678643364921e+1, to dnsOA from rsvA : response(2, label(632) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm(1.7945791459905671e+1, to dnsOA from rsvA : response(3, label(645) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm(1.8031754744971426e+1, to dnsOA from rsvA : response(4, label(521) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm(1.8099418840767878e+1, to dnsOA from rsvA : response(5, label(490) . 'internet . 'com . root, nil, nil, nil, 0)) ; tm(1.813707361788142e+1, to dnsOA from rsvA : response(6, label(633) . 'internet . 'com . root, nil, nil, nil, 0))) > 
< umdA : UM-EQ | markov: ("batch" |-> "wait_batch" |-> 1.0, "single" |-> "wait_single" |-> 1.0, "wait_batch" |-> ("batch" |-> 5.0e-1, "single" |-> 5.0e-1), "wait_single" |-> ("batch" |-> 5.0e-1, "single" |-> 5.0e-1)), actions: ("batch" |-> jo(("num_to_resolve" |-> jo(("max" |-> jn(10), "min" |-> jn(2), "random" |-> js("uniform"))), "type" |-> js( "resolve_a_batch"))), "single" |-> jo(("start" |-> jb(true), "type" |-> js("resolve_a"))), "wait_batch" |-> jo(("sleep" |-> jo(("mean" |-> jf( 2.0e+1), "random" |-> js("gaussian"), "std" |-> jf(2.0))), "type" |-> js("wait"))), "wait_single" |-> jo(("sleep" |-> jo(("mean" |-> jf( 2.0e+1), "random" |-> js("gaussian"), "std" |-> jf(2.0))), "type" |-> js("wait")))), curState: "single", nsteps: 96, actAddress: dnsQA, w4: ( to umdA from umdA : actionR("ok")), default: "single", mSum: ("batch" |-> 1.0, "single" |-> 1.0, "wait_batch" |-> 1.0, "wait_single" |-> 1.0), stateLM: ("batch" |-> jl(js("wait_batch")), "single" |-> jl(js( "wait_single")), "wait_batch" |-> jl(js("batch") ; js("single")), "wait_single" |-> jl(js("batch") ; js("single"))), weightLM: ("batch" |-> jl(jf(1.0)), "single" |-> jl(jf(1.0)), "wait_batch" |-> jl(jf( 5.0e-1) ; jf(1.0)), "wait_single" |-> jl(jf(5.0e-1) ; jf(1.0))), stopTime: 3.0e+1 >
)



      