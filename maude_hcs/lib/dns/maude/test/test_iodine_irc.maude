sload ../probabilistic/iodine_dns.maude
sload ../common/_aux.maude

sload ../../../common/maude/cp2-interfaces.maude
sload ../../../irc/irc_prob.maude
sload ../../../irc/irc_monitor.maude

mod TEST_IODINE_IRC is
  pr IRC .
  pr IRC-DISPATCHER-INTERFACE .
  pr IODINE_NODE .
  pr IODINE_DNS .

  ---------------------------------------------------
  --- Iodine parameters and configs
  ---------------------------------------------------
  eq packetSize = 1000 .
  eq maxPacketSize  = 967 .

  op aliceZonePwnd2Com : -> List{Record} .
  eq aliceZonePwnd2Com =
    < 'pwnd2 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'pwnd2 . 'com . root, ns, 3600.0, 'ns . 'pwnd2 . 'com . root >
    < 'ns . 'pwnd2 . 'com . root, a, 3600.0, serverAliceIodineServerAddr >
    < 'www0 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 0 . 1 . 2 >
    < 'www1 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 1 . 1 . 2 >
    < wildcard . 'pwnd2 . 'com . root, txt, 3600.0, nullAddr >
  .
  op bobZonePwnd2Com : -> List{Record} .
  eq bobZonePwnd2Com =
    < 'pwnd2 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'pwnd2 . 'com . root, ns, 3600.0, 'ns . 'pwnd2 . 'com . root >
    < 'ns . 'pwnd2 . 'com . root, a, 3600.0, serverBobIodineServerAddr >
    < 'www0 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 0 . 1 . 2 >
    < 'www1 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 1 . 1 . 2 >
    < wildcard . 'pwnd2 . 'com . root, txt, 3600.0, nullAddr >
  .

  ---------------------------------------------------
  --- Addresses
  ---------------------------------------------------
  ops aliceIrcClientAddr bobIrcClientAddr : -> Address .
  ops ircServerAddr                       : -> Address .
  ops ircMonitorAddr iodineMonitorAddr    : -> Address .

  ops aliceIfaceAddr bobIfaceAddr             : -> Address .
  ops serverAliceIfaceAddr serverBobIfaceAddr : -> Address .

  ops aliceSendAppAddr aliceIodineClientAddr                : -> Address .
  ops bobSendAppAddr bobIodineClientAddr                    : -> Address .
  ops serverAliceRcvAppAddr serverBobRcvAppAddr             : -> Address .
  ops serverAliceIodineServerAddr serverBobIodineServerAddr : -> Address .

  ---------------------------------------------------
  --- Message schedules
  ---
  --- imd(delaySeconds, room, messageSize)
  --- The delay is relative to the first scheduled send (set via ircMsgSendTime).
  --- Message text is generated by genIrcText(userId, counter, size).
  ---------------------------------------------------
  op aliceMessages : -> IrcMsgDelayList .
  eq aliceMessages  =   imd( 0.000, "#room1", 120)
                     :: imd( 4.000, "#room1", 200) 
  .
  op bobMessages   : -> IrcMsgDelayList .
  eq bobMessages    =   imd( 3.000, "#room1", 500)
  .

  ---------------------------------------------------
  --- Actors
  ---------------------------------------------------
  ops aliceIrcClient bobIrcClient ircServer ircMonitor iodineMonitor                  : -> Actor . 
  ops aliceIface bobIface serverAliceIface serverBobIface                             : -> Actor . 
  ops aliceSendApp bobSendApp serverAliceRcvApp serverBobRcvApp                       : -> Actor .  
  ops aliceIodineClient bobIodineClient serverAliceIodineServer serverBobIodineServer : -> Actor .  

  --- IRC Actors ---
  eq aliceIrcClient = mkIrcClient(aliceIrcClientAddr,
                                  aliceIfaceAddr,
                                  "alice",
                                  aliceMessages)
  .
  eq bobIrcClient   = mkIrcClient(bobIrcClientAddr,
                                  bobIfaceAddr,
                                  "bob",
                                  bobMessages)
  .
  eq ircServer      = mkIrcServer(ircServerAddr) .
  eq ircMonitor     = mkIrcMonitor(ircMonitorAddr,
                                   (aliceIrcClientAddr ;; bobIrcClientAddr ;; ircServerAddr),
                                   (aliceIrcClientAddr ;; bobIrcClientAddr),
                                   (rm("#room1", aliceIrcClientAddr ;; bobIrcClientAddr)))
  .

  --- Interface Actors ---
  eq aliceIface       = mkIrcByteSeqIface(aliceIfaceAddr,
                                          aliceIrcClientAddr,
                                          aliceSendAppAddr,
                                          aliceSendAppAddr)
  .
  eq bobIface         = mkIrcByteSeqIface(bobIfaceAddr,
                                          bobIrcClientAddr,
                                          bobSendAppAddr,
                                          bobSendAppAddr)
  .
  eq serverAliceIface = mkIrcByteSeqIface(serverAliceIfaceAddr,
                                          ircServerAddr,
                                          serverAliceRcvAppAddr,
                                          serverAliceRcvAppAddr)
  .
  eq serverBobIface   = mkIrcByteSeqIface(serverBobIfaceAddr,
                                          ircServerAddr,
                                          serverBobRcvAppAddr,
                                          serverBobRcvAppAddr)
  .

  --- Iodine Actors ---
  eq iodineMonitor            = mkWMonitor(iodineMonitorAddr) .
  eq aliceSendApp             = mkSendApp(aliceSendAppAddr,
                                          serverAliceRcvAppAddr,
                                          aliceIfaceAddr,
                                          aliceIodineClientAddr)
  .
  eq bobSendApp               = mkSendApp(bobSendAppAddr,
                                          serverBobRcvAppAddr,
                                          bobIfaceAddr,
                                          bobIodineClientAddr)
  .
  eq serverAliceRcvApp        = mkRcvApp(serverAliceRcvAppAddr,
                                         aliceSendAppAddr,
                                         serverAliceIfaceAddr,
                                         aliceIodineClientAddr)
  .
  eq serverBobRcvApp          = mkRcvApp(serverBobRcvAppAddr,
                                         bobSendAppAddr,
                                         serverBobIfaceAddr,
                                         bobIodineClientAddr)
  .
  eq aliceIodineClient        = makeWClient(aliceIodineClientAddr,
                                            serverAliceIodineServerAddr, 
                                            'pwnd2 . 'com . root,
                                            a,
                                            0.0)
  .
  eq bobIodineClient          = makeWClient(bobIodineClientAddr,
                                            serverBobIodineServerAddr,
                                            'pwnd2 . 'com . root,
                                            a,
                                            0.0)
  .
  eq serverAliceIodineServer  = makeWNameServer(serverAliceIodineServerAddr,
                                                0.0,
                                                (aliceZonePwnd2Com))
  .
  eq serverBobIodineServer    = makeWNameServer(serverBobIodineServerAddr,
                                                0.0,
                                                (bobZonePwnd2Com))
  .

  ---------------------------------------------------
  --- Initial configuration
  ---------------------------------------------------
  op initState : -> Config .
  eq initState =
    rCtr(0)
    aliceIrcClient
    bobIrcClient
    ircServer
    ircMonitor
    aliceIface
    bobIface
    serverAliceIface
    serverBobIface
    iodineMonitor
    aliceSendApp
    bobSendApp
    serverAliceRcvApp
    serverBobRcvApp
    aliceIodineClient
    bobIodineClient
    serverAliceIodineServer
    serverBobIodineServer
    [0.65, (to aliceIfaceAddr from aliceIrcClientAddr
             : JoinChannel(makeIrcChannelName("#room1"), aliceIrcClientAddr)), 0]
    [1.70, (to bobIfaceAddr from bobIrcClientAddr 
             : JoinChannel(makeIrcChannelName("#room1"), bobIrcClientAddr)), 0]
    --- Phase 3: IRC message send timers.
    --- ircMsgSendTime is the internal trigger used by the IRC actor's
    --- message-schedule machinery (from irc_prob.maude).
    [2.00, (to aliceIrcClientAddr from aliceIrcClientAddr : ircMsgSendTime), 0]
    [4.00, (to bobIrcClientAddr from bobIrcClientAddr : ircMsgSendTime), 0]
  .

  ---------------------------------------------------
  --- Run parameters
  ---------------------------------------------------
  op limit : -> Float .
  eq limit = 20.0 .    --- simulate 30 simulated seconds

  op initConfig : -> Config .
  eq initConfig = run({0.0 | nil} initState, limit) .
endm

set print attribute on .
rew initConfig .
eof

