  .


  ---------------------------------------------------
  --- Actors Setup
  ---------------------------------------------------
  ops ircClient1 ircClient2 ircClient3 ircClient4 ircServer s3SrvAct iodineMonitor : -> Actor .
  ops ircClient1UserModel ircClient2UserModel ircClient3UserModel ircClient4UserModel : -> Actor .
  
  ops client1Iface server1Iface wtClient1 wtProxy1 : -> Actor .
  ops wtClient1NetClient wtProxy1NetServer : -> Actor .
  ops client2Iface server2Iface obfs4Client2 obfs4Server2 : -> Actor .
  ops obfs4Client2NetClient obfs4Server2NetServer : -> Actor .
  ops client3Iface server3Iface umac3Act cmac3Act pua3Act sdkac3Act umas3Act cmas3Act aha3Act sdkas3Act : -> Actor .
  ops skyhookClient3NetClient skyhookServer3NetClient skyhookNetServer : -> Actor .
  ops client4Iface serverIface4 sendApp4 rcvApp4 iodineClient4 serverIodineServer4 : -> Actor .
  ops iodineClient4NetClient iodineServer4NetServer : -> Actor .

  ops ircClient5 ircClient5UserModel : -> Actor .
  ops client5Iface server5Iface umac5Act cmac5Act mcac5Act edac5Act umas5Act cmas5Act mcas5Act edas5Act : -> Actor .
  ops mastodonClient5NetClient mastodonServer5NetClient masNetServer masSrvAct : -> Actor .

  ops corp1Dns corp2Dns corp3Dns corp4Dns corp5Dns  : -> Actor .
  ops servDns                                       : -> Actor .
  ops publicResolver rootDns authDns tldDns         : -> Actor .
  ops corp1NetClient corp2NetClient corp3NetClient corp4NetClient corp5NetClient  : -> Actor .
  ops servNetClient                                                               : -> Actor .
  ops publicResolverNetClient rootDnsNetClient tldDnsNetClient authDnsNetClient   : -> Actor .
  
  op advAddr : -> Address .
  op advActor : -> Actor .
  eq advActor = mkAdversaryCp3(advAddr) .

  --- Client 1 (Webtunnel) Setup
  eq ircClient1          = mkIrcClient-v2(ircClient1Addr, client1IfaceAddr, "Client1") .
  eq ircClient1UserModel = mkIrcUMV2Actor(ircClient1UserModelAddr, "irc-test", ircClient1Addr) .
  eq client1Iface        = mkIrcByteSeqIface(client1IfaceAddr, ircClient1Addr, wtClient1Addr) .
  eq server1Iface        = mkIrcByteSeqIface(server1IfaceAddr, ircServerAddr, wtProxy1Addr) .

  --- WtClient normally relies on learning the address of its local IRC client dynamically when the local client sends its first outbound message.
  --- Because the server's notification arrived before Alice sent her first outbound message, wtClient tried to forward the notification to nullAddr.
  --- Maude doesn't have an actor for nullAddr, so the to nullAddr message got permanently stuck at the very front of the event queue. 
  --- To circumvent this, we initialize wtClient with the address of its local IRC client client1IfaceAddr.

  eq wtClient1 =
    < wtClient1Addr : WtClient |
        thisAddr:        wtClient1Addr,
        serverProxyAddr: wtProxy1Addr,
        ircServerAddr:   ircServerAddr,
        ircClientAddr:   client1IfaceAddr,
        tlsServerName:   "irc.example.com",
        upgradePath:     "secret/path/v1",
        tunnelState:     Closed,
        pendingMsgs:     emptyQueue >
  .
  eq wtProxy1             = makeWtServerProxy(wtProxy1Addr, server1IfaceAddr) .
  eq wtClient1NetClient   = makeNetClient(wtClient1NetClientAddr,
                                          wtProxy1Addr,
                                          wtClient1Addr,
                                          true,
                                          a(cl[1], dns, dns, cl, 0),
                                          **** Carolyn: What should it be here?
                                          nullName)
  .
  eq wtProxy1NetServer    = makeNetServer(wtProxy1NetServerAddr, wtProxy1Addr) .
  eq corp1Dns             = mkNameServer(corp1DnsAddr, (zoneCorp1Com), publicDnsAddr) .

  --- Client 2 (OBFS4) Setup
  eq ircClient2             = mkIrcClient-v2(ircClient2Addr, client2IfaceAddr, "Client2") .
  eq ircClient2UserModel    = mkIrcUMV2Actor(ircClient2UserModelAddr, "irc-test", ircClient2Addr) .
  eq client2Iface           = mkIrcByteSeqIface(client2IfaceAddr, ircClient2Addr, obfs4Client2Addr) .
  eq obfs4Client2           = makeObfs4Node(obfs4Client2Addr, client2IfaceAddr, obfs4Server2Addr) .
  eq server2Iface           = mkIrcByteSeqIface(server2IfaceAddr, ircServerAddr, obfs4Server2Addr) .
  eq obfs4Server2           = makeObfs4Node(obfs4Server2Addr, server2IfaceAddr, obfs4Client2Addr) .
  eq obfs4Client2NetClient  = makeNetClient(obfs4Client2NetClientAddr,
                                            obfs4Server2Addr,
                                            obfs4Client2Addr,
                                            true,
                                            **** Carolyn: What should it be here?
                                            a(cl[2], dns, dns, cl, 0),
                                            nullName)
  .
  eq obfs4Server2NetServer  = makeNetServer(obfs4Server2NetServerAddr, obfs4Server2Addr) .
  eq corp2Dns               = mkNameServer(corp2DnsAddr, (zoneCorp2Com), publicDnsAddr) .

  --- Client 3 (Skyhook) Setup
  eq ircClient3               = mkIrcClient-v2(ircClient3Addr, client3IfaceAddr, "Client3") .
  eq ircClient3UserModel      = mkIrcUMV2Actor(ircClient3UserModelAddr, "irc-test", ircClient3Addr) .
  eq client3Iface             = mkIrcByteSeqIface(client3IfaceAddr, ircClient3Addr, cmac3Addr) .
  eq umac3Act                 = mkUMactor(umac3Addr, skyhook-um-mamodel-1-ma, cmac3Addr) .
  eq cmac3Act                 = mkCMSimpleBi(cmac3Addr, client3IfaceAddr, pua3Addr) .
  eq pua3Act                  = makeSkyhookPU(pua3Addr, cmac3Addr, sdkac3Addr, "s_to_c_bucket_a", "c_to_s_bucket_a", "s_to_c_uuid_a", "c_to_s_uuid_a-hash") .
  eq sdkac3Act                = makeS3Client(sdkac3Addr, s3SrvAddr) .
  eq server3Iface             = mkIrcByteSeqIface(server3IfaceAddr, ircServerAddr, cmas3Addr) .
  eq umas3Act                 = mkUMactor(umas3Addr, skyhook-um-mamodel-1-ma, cmas3Addr) .
  eq cmas3Act                 = mkCMSimpleBi(cmas3Addr, server3IfaceAddr, aha3Addr) .
  eq aha3Act                  = mkSkyhookAH(aha3Addr, cmas3Addr, sdkas3Addr, "c_to_s_bucket_a", "s_to_c_bucket_a", "c_to_s_uuid_a", "s_to_c_uuid_a", "s_to_c_uuid_a", 6) .
  eq sdkas3Act                = makeS3Client(sdkas3Addr, s3SrvAddr) .
  eq skyhookClient3NetClient  = makeNetClient(skyhookClient3NetClientAddr,
                                              s3SrvAddr,
                                              sdkac3Addr,
                                              true,
                                              a(cl[3], dns, dns, cl, 0),
                                              **** Carolyn: What should it be here?
                                              nullName)
  .
  eq skyhookNetServer = makeNetServer(skyhookNetServerAddr, s3SrvAddr) .
  eq skyhookServer3NetClient  = makeNetClient(skyhookServer3NetClientAddr,
                                              s3SrvAddr,
                                              sdkas3Addr,
                                              true,
                                              a(srvN, dns, dns, cl, 0),
                                              **** Carolyn: What should it be here?
                                              nullName)
  .
  eq corp3Dns                 = mkNameServer(corp3DnsAddr, (zoneCorp3Com), publicDnsAddr) .

  --- Client 4 (Iodine) Setup
  eq ircClient4             = mkIrcClient-v2(ircClient4Addr, client4IfaceAddr, "Client4") .
  eq ircClient4UserModel    = mkIrcUMV2Actor(ircClient4UserModelAddr, "irc-test", ircClient4Addr) .
  eq client4Iface           = mkIrcByteSeqIface(client4IfaceAddr, ircClient4Addr, sendApp4Addr) .
  eq serverIface4           = mkIrcByteSeqIface(serverIface4Addr, ircServerAddr, rcvApp4Addr) .
  eq sendApp4               = mkSendApp(sendApp4Addr, rcvApp4Addr, client4IfaceAddr, iodineClient4Addr) .
  eq rcvApp4                = mkRcvApp(rcvApp4Addr, sendApp4Addr, serverIface4Addr, iodineClient4Addr) .
  eq iodineClient4          = makeWClient(iodineClient4Addr, serverIodineServer4Addr, 'pwnd2 . 'com . root, a, 0.0) .
  eq serverIodineServer4    = makeWNameServer(serverIodineServer4Addr, 0.0, zonePwnd2Com4) .
  eq iodineClient4NetClient = makeNetClient(iodineClient4NetClientAddr,
                                            serverIodineServer4Addr,
                                            iodineClient4Addr,
                                            true,
                                            a(cl[4], dns, dns, cl, 0),
                                            **** Carolyn: What should it be here?
                                            nullName)
  .
  eq iodineServer4NetServer = makeNetServer(iodineServer4NetServerAddr, serverIodineServer4Addr) .
  eq corp4Dns               = mkNameServer(corp4DnsAddr, (zoneCorp4Com), publicDnsAddr) .
  eq iodineMonitor          = mkWMonitor(iodineMonitorAddr) .

  --- Client 5 (Mastodon) Setup
  eq ircClient5          = mkIrcClient-v2(ircClient5Addr, client5IfaceAddr, "Client5") .
  eq ircClient5UserModel = mkIrcUMV2Actor(ircClient5UserModelAddr, "irc-test", ircClient5Addr) .
  eq client5Iface        = mkIrcByteSeqIface(client5IfaceAddr, ircClient5Addr, cmac5Addr) .
  eq umac5Act            = mkUMactor(umac5Addr, mastodon-client-config-mastodon-bidi-ma, cmac5Addr) .
  eq cmac5Act            = mkCMSndRcvActor(cmac5Addr, edac5Addr, mcac5Addr, client5IfaceAddr, "client5", "server5") .
  eq mcac5Act            = makeMastodonClient(mcac5Addr, masSrvAddr, cmac5Addr) .
  eq edac5Act            = makeDestiniActor(edac5Addr, ed-images) .
  
  eq server5Iface        = mkIrcByteSeqIface(server5IfaceAddr, ircServerAddr, cmas5Addr) .
  eq umas5Act            = mkUMactor(umas5Addr, mastodon-client-config-mastodon-bidi-ma, cmas5Addr) .
  eq cmas5Act            = mkCMSndRcvActor(cmas5Addr, edas5Addr, mcas5Addr, server5IfaceAddr, "server5", "client5") .
  eq mcas5Act            = makeMastodonClient(mcas5Addr, masSrvAddr, cmas5Addr) .
  eq edas5Act            = makeDestiniActor(edas5Addr, ed-images) .
  eq corp5Dns            = mkNameServer(corp5DnsAddr, (zoneCorp5Com), publicDnsAddr) .
  
  eq mastodonClient5NetClient = makeNetClient(mastodonClient5NetClientAddr,
                                              masSrvAddr,
                                              mcac5Addr,
                                              true,
                                              a(cl[5], dns, dns, cl, 0),
                                              **** Carolyn: What should it be here?
                                              nullName)
  .
  eq masNetServer      = makeNetServer(masNetServerAddr, masSrvAddr) .
  eq mastodonServer5NetClient = makeNetClient(mastodonServer5NetClientAddr,
                                              masSrvAddr,
                                              mcas5Addr,
                                              true,
                                              a(srvN, dns, dns, cl, 0),
                                              **** Carolyn: What should it be here?
                                              nullName)
  .

  --- Base Infrastructure Setup
  eq s3SrvAct       = makeS3Server(s3SrvAddr) .
  eq masSrvAct      = makeMastodonServer(masSrvAddr) .
  eq ircServer      = mkIrcServer(ircServerAddr) .
  eq servDns        = mkNameServer(servDnsAddr, (zoneServCom), publicDnsAddr) .
  eq publicResolver = mkResolver(publicDnsAddr, resolverCache, sb) .
  eq rootDns        = mkNameServer(rootDnsAddr, (zone), nullAddr) .
  eq tldDns         = mkNameServer(tldDnsAddr, (zoneCom), nullAddr) .
  eq authDns        = mkNameServer(authDnsAddr, (zoneInternetCom), nullAddr) .

  eq corp1NetClient = makeNetClient(a(cl[1], udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(cl[1], dns, dns, cl, 0),
                                    true)
  .
  eq corp2NetClient = makeNetClient(a(cl[2], udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(cl[2], dns, dns, cl, 0),
                                    true)
  .
  eq corp3NetClient = makeNetClient(a(cl[3], udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(cl[3], dns, dns, cl, 0),
                                    true)
  .
  eq corp4NetClient = makeNetClient(a(cl[4], udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(cl[4], dns, dns, cl, 0),
                                    true)
  .
  eq corp5NetClient = makeNetClient(a(cl[5], udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(cl[5], dns, dns, cl, 0),
                                    true)
  .
  eq servNetClient  = makeNetClient(a(srvN, udp, dns, cl, 0),
                                    publicDnsAddr,
                                    a(srvN, dns, dns, cl, 0),
                                    true)
  .
  eq publicResolverNetClient  = makeNetClient(a(dnsN, udp, dns, cl, 0),
                                              publicDnsAddr,
                                              publicDnsAddr,
                                              true)
  .
  *** Carolyn: Should there not be servers for these clients?

  *** Carolyn: This seems wrong too.
  eq rootDnsNetClient         = makeNetClient(a(dnsN, udp, dns, cl, 0),
                                              rootDnsAddr,
                                              rootDnsAddr,
                                              true)
  .
  eq tldDnsNetClient          = makeNetClient(a(dnsN, udp, dns, cl, 0),
                                              tldDnsAddr,
                                              tldDnsAddr,
                                              true)
  .
  eq authDnsNetClient         = makeNetClient(a(dnsN, udp, dns, cl, 0),
                                              authDnsAddr,
                                              authDnsAddr,
                                              true)
  .

  ---------------------------------------------------
  --- Initial State Configuration
  ---------------------------------------------------
  op initState : Nat -> Config .
  eq initState(j) =
    rCtr(j + 8)

    --- Core Shared Infrastructure
    ircServer s3SrvAct iodineMonitor
    mkIrcMonitor(ircMonitorAddr)
    servDns servNetClient

    --- Client 1 Entities (Webtunnel)
    ircClient1 ircClient1UserModel client1Iface server1Iface wtClient1 wtProxy1
    wtClient1NetClient wtProxy1NetServer
    corp1Dns corp1NetClient
    
    --- Client 2 Entities (OBFS4)
    ircClient2 ircClient2UserModel client2Iface server2Iface obfs4Client2 obfs4Server2
    obfs4Client2NetClient obfs4Server2NetServer
    corp2Dns corp2NetClient
    
    --- Client 3 Entities (Skyhook)
    ircClient3 ircClient3UserModel client3Iface umac3Act cmac3Act pua3Act sdkac3Act server3Iface umas3Act cmas3Act aha3Act sdkas3Act
    skyhookClient3NetClient skyhookNetServer skyhookServer3NetClient
    corp3Dns corp3NetClient
    
    --- Client 4 (Iodine)
    ircClient4 ircClient4UserModel client4Iface serverIface4 sendApp4 rcvApp4 iodineClient4 serverIodineServer4
    iodineClient4NetClient iodineServer4NetServer
    corp4Dns corp4NetClient

    --- Client 5 (Mastodon)
    ircClient5 ircClient5UserModel client5Iface server5Iface umac5Act cmac5Act mcac5Act edac5Act umas5Act cmas5Act mcas5Act edas5Act
    mastodonClient5NetClient masNetServer mastodonServer5NetClient
    corp5Dns corp5NetClient
    
    masSrvAct
    advActor

    --- DNS Infrastructure
    publicResolver publicResolverNetClient
    rootDns rootDnsNetClient tldDns tldDnsNetClient authDns authDnsNetClient

    --- Timers & Execution Triggers

    [0.001, (to aha3Addr from aha3Addr : SkyhookStartCmd), 0]
    [0.20, (to wtClient1Addr from wtClient1Addr : WtStartCmd), 0]

    [1.0 + genRandomX(j, 0.0, 0.0001), (to umac3Addr from umac3Addr : actionR("ok")), 0]
    [1.0 + genRandomX(s s j, 0.0, 0.0001), (to umas3Addr from umas3Addr : actionR("ok")), 0]
    
    [1.0 + genRandomX(j, 0.0, 0.0001), (to umac5Addr from umac5Addr : actionR("ok")), 0]
    [1.0 + genRandomX(s s j, 0.0, 0.0001), (to umas5Addr from umas5Addr : actionR("ok")), 0]

    mkJoin(2.0, "#chat", ircClient1Addr, ircServerAddr, server1IfaceAddr)
    mkJoin(2.1, "#general", ircClient1Addr, ircServerAddr, server1IfaceAddr)
    mkJoin(2.2, "#random", ircClient1Addr, ircServerAddr, server1IfaceAddr)

    mkJoin(2.3, "#chat", ircClient2Addr, ircServerAddr, server2IfaceAddr)
    mkJoin(2.4, "#general", ircClient2Addr, ircServerAddr, server2IfaceAddr)
    mkJoin(2.5, "#random", ircClient2Addr, ircServerAddr, server2IfaceAddr)

    mkJoin(2.6, "#chat", ircClient3Addr, ircServerAddr, server3IfaceAddr)
    mkJoin(2.7, "#general", ircClient3Addr, ircServerAddr, server3IfaceAddr)
    mkJoin(2.8, "#random", ircClient3Addr, ircServerAddr, server3IfaceAddr)

    mkJoin(2.9, "#chat", ircClient4Addr, ircServerAddr, serverIface4Addr)
    mkJoin(3.0, "#general", ircClient4Addr, ircServerAddr, serverIface4Addr)
    mkJoin(3.1, "#random", ircClient4Addr, ircServerAddr, serverIface4Addr)

    mkJoin(3.2, "#chat", ircClient5Addr, ircServerAddr, server5IfaceAddr)
    mkJoin(3.3, "#general", ircClient5Addr, ircServerAddr, server5IfaceAddr)
    mkJoin(3.4, "#random", ircClient5Addr, ircServerAddr, server5IfaceAddr)

    [20.0, (to ircClient1UserModelAddr from ircClient1UserModelAddr : burstDelayTO), 0]
    [21.0, (to ircClient2UserModelAddr from ircClient2UserModelAddr : burstDelayTO), 0]
    [22.0, (to ircClient3UserModelAddr from ircClient3UserModelAddr : burstDelayTO), 0]
    [23.0, (to ircClient4UserModelAddr from ircClient4UserModelAddr : burstDelayTO), 0]
    [24.0, (to ircClient5UserModelAddr from ircClient5UserModelAddr : burstDelayTO), 0]
  .

  ---------------------------------------------------
  --- Run Limits and Initial Configurations
  ---------------------------------------------------
  op slimit : -> Float .
  eq slimit = 1000.0 .

  op initConfig : -> Config .
  rl[init]: initConfig => run({0.0 | nil} initState(counter), slimit) .
endm

set print attribute on .
rew initConfig .
q
