    aaa(a(srvN, dns, dns, cl, 0), a(dnsN, dns, dns, srv, 0), LinkType-Dns)

    aaa(IXP-DEFAULT-ADDR, a(cl[1], dns, dns, cl, 0), LinkType-Dns)
    aaa(a(cl[1], dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
    aaa(IXP-DEFAULT-ADDR, a(cl[2], dns, dns, cl, 0), LinkType-Dns)
    aaa(a(cl[2], dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
    aaa(IXP-DEFAULT-ADDR, a(cl[3], dns, dns, cl, 0), LinkType-Dns)
    aaa(a(cl[3], dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
    aaa(IXP-DEFAULT-ADDR, a(cl[4], dns, dns, cl, 0), LinkType-Dns)
    aaa(a(cl[4], dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
    aaa(IXP-DEFAULT-ADDR, a(cl[5], dns, dns, cl, 0), LinkType-Dns)
    aaa(a(cl[5], dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
    aaa(IXP-DEFAULT-ADDR, a(srvN,  dns, dns, cl, 0), LinkType-Dns)
    aaa(a(srvN,  dns, dns, cl, 0), IXP-DEFAULT-ADDR, LinkType-Dns)

    aaa(a(dnsN, dns, dns, srv, 0), IXP-DEFAULT-ADDR, LinkType-Dns)
