sload ../../network/net_prob-clt.maude
sload ../../common/maude/structured-addresses.maude

mod COMBINED_IRC_EXPERIMENTS is
  pr SCHEDULER .
  pr USER-ACTION-ACTOR .
  pr SKYHOOK-UM-MAMODEL-1 .
  pr IRC-V2 .
  pr IRC-MAMODEL-V2 .
  pr IRC-USER-ACTION-ACTOR-V2 .
  pr IRC-BYTESEQ-INTERFACE .
  pr CONTENT-MANAGER-SIMPLE-BI .
  inc ENC-DEC .
  inc CONTENT-MANAGER-BIDIR .
  inc MASTODON .
  inc MASTODON-CLIENT-CONFIG-MASTODON-BIDI-MAMODEL .
  inc MASTODON-SERVER-CONFIG-MASTODON-BIDI-MAMODEL .
  pr SKYHOOK .
  pr S3_PROTOCOL .
  pr IRC_MONITOR .
  pr OBFS4 .
  pr APP_CHATS .
  pr IRC_NODE .
  pr WEBTUNNEL .
  pr IRC_NAMES .
  pr IODINE_NODE .
  pr IODINE_DNS .
  pr TCP_SOCKET .
  pr NETWORK_NODE .
  pr NETWORK_CONNECTION .
  inc STRUCTURED-ADDRESSES .

  vars j : Nat .

  eq encOH(fsize:Nat,ksize:Nat) = 0 .
  eq noiseMin(msg:Msg)          = 0.001 .
  ***** Global constants  
  **** the user model database
  eq MAModelMap                 = ("irc-test" |-> irc-mamodel-v2 ) .
  *** for the default case
  eq noiseMax(msg:Msg)          = 0.00001 .
     
  eq packetSize                 = 1000 .
  eq maxPacketSize              = 967 .

  op ed-images : -> ByteSeqL .
  eq ed-images =
       image(1, 3779, 500)
    :: image(2, 2405, 1000)
    :: image(3, 36861, 1000)
    :: image(4, 25377, 500)
    :: image(5, 2440, 300)
    :: image(6, 1275, 300)
    :: image(7, 7710, 1000)
    :: image(8, 3577, 500)
    :: image(9, 3415, 300)
    :: image(10, 74123, 600)
  .

  ---------------------------------------------------
  --- DNS Zone Configurations
  ---------------------------------------------------
  op zone : -> List{Record} .
  eq zone =
    < root, soa, 3600.0, soaData(3600.0) >
    < root, ns, 3600.0, 'a . 'root-servers . 'net . root >
    < 'a . 'root-servers . 'net . root, a, 3600.0, rootDnsAddr >
    < 'com . root, ns, 3600.0, 'ns . 'com . root >
    < 'ns . 'com . root, a, 3600.0, tldDnsAddr >
  .

  op zoneCom : -> List{Record} .
  eq zoneCom =
    < 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'com . root, ns, 3600.0, 'ns . 'com . root >
    < 'ns . 'com . root, a, 3600.0, tldDnsAddr >
    < 'pwnd . 'com . root, ns, 3600.0, 'ns . 'pwnd . 'com . root >
    < 'ns . 'pwnd . 'com . root, a, 3600.0, authDnsAddr >
    < 'internet . 'com . root, ns, 3600.0, 'ns . 'internet . 'com . root >
    < 'ns . 'internet . 'com . root, a, 3600.0, authDnsAddr >
    < 'corp1 . 'com . root, ns, 3600.0, 'ns . 'corp1 . 'com . root >
    < 'ns . 'corp1 . 'com . root, a, 3600.0, corp1DnsAddr >
    < 'corp2 . 'com . root, ns, 3600.0, 'ns . 'corp2 . 'com . root >
    < 'ns . 'corp2 . 'com . root, a, 3600.0, corp2DnsAddr >
    < 'corp3 . 'com . root, ns, 3600.0, 'ns . 'corp3 . 'com . root >
    < 'ns . 'corp3 . 'com . root, a, 3600.0, corp3DnsAddr >
    < 'corp4 . 'com . root, ns, 3600.0, 'ns . 'corp4 . 'com . root >
    < 'ns . 'corp4 . 'com . root, a, 3600.0, corp4DnsAddr >
    < 'corp5 . 'com . root, ns, 3600.0, 'ns . 'corp5 . 'com . root >
    < 'ns . 'corp5 . 'com . root, a, 3600.0, corp5DnsAddr >
    < 'serv . 'com . root, ns, 3600.0, 'ns . 'serv . 'com . root >
    < 'ns . 'serv . 'com . root, a, 3600.0, servDnsAddr >
  .

  op zoneInternetCom : -> List{Record} .
  eq zoneInternetCom =
    < 'internet . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'internet . 'com . root, ns, 3600.0, 'ns . 'internet . 'com . root >
    < 'ns . 'internet . 'com . root, a, 3600.0, authDnsAddr >
    < 'tmp0 . 'internet . 'com . root, a, 0.0, 1 . 0 . 1 . 2 >
    < 't1 . 'pwnd . 'com . root, ns, 3600.0, 'ns . 't1 . 'pwnd . 'com . root >
    < 'ns . 't1 . 'pwnd . 'com . root, a, 3600.0, serverIodineServer4Addr >
    < 'mastodon . 'pwnd . 'com . root, a, 0.0, masSrvAddr >
    < wildcard . 'internet . 'com . root, a, 0.0, 1 . 1 . 1 . 2 >
  .

  op zonePwnd2Com4 : -> List{Record} .
  eq zonePwnd2Com4 =
    < 'pwnd2 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'pwnd2 . 'com . root, ns, 3600.0, 'ns . 'pwnd2 . 'com . root >
    < 'ns . 'pwnd2 . 'com . root, a, 3600.0, serverIodineServer4Addr >
    < 'www0 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 0 . 1 . 2 >
    < 'www1 . 'pwnd2 . 'com . root, a, 3600.0, 2 . 1 . 1 . 2 >
    < wildcard . 'pwnd2 . 'com . root, txt, 3600.0, nullAddr > .

  op zoneCorp1Com  : -> List{Record} .
  eq zoneCorp1Com  =
    < 'corp1 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'corp1 . 'com . root, ns, 3600.0, 'ns . 'corp1 . 'com . root >
    < 'ns . 'corp1 . 'com . root, a, 3600.0, corp1DnsAddr >
    ---                                   What should these addresses be?
    < 'tmp1 . 'corp1 . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'corp1 . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  op zoneCorp2Com  : -> List{Record} .
  eq zoneCorp2Com  =
    < 'corp2 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'corp2 . 'com . root, ns, 3600.0, 'ns . 'corp2 . 'com . root >
    < 'ns . 'corp2 . 'com . root, a, 3600.0, corp2DnsAddr >
    ---                                   What should these addresses be?
    < 'tmp2 . 'corp2 . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'corp2 . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  op zoneCorp3Com  : -> List{Record} .
  eq zoneCorp3Com  =
    < 'corp3 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'corp3 . 'com . root, ns, 3600.0, 'ns . 'corp3 . 'com . root >
    < 'ns . 'corp3 . 'com . root, a, 3600.0, corp3DnsAddr >
    ---                                   What should these addresses be?
    < 'tmp3 . 'corp3 . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'corp3 . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  op zoneCorp4Com  : -> List{Record} .
  eq zoneCorp4Com  =
    < 'corp4 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'corp4 . 'com . root, ns, 3600.0, 'ns . 'corp4 . 'com . root >
    < 'ns . 'corp4 . 'com . root, a, 3600.0, corp4DnsAddr >
    ---                                   What should these addresses be?
    < 'tmp4 . 'corp4 . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'corp4 . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  op zoneCorp5Com  : -> List{Record} .
  eq zoneCorp5Com  =
    < 'corp5 . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'corp5 . 'com . root, ns, 3600.0, 'ns . 'corp5 . 'com . root >
    < 'ns . 'corp5 . 'com . root, a, 3600.0, corp5DnsAddr >
    ---                                   What should these addresses be?
    < 'tmp5 . 'corp5 . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'corp5 . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  op zoneServCom  : -> List{Record} .
  eq zoneServCom  =
    < 'serv . 'com . root, soa, 3600.0, soaData(3600.0) >
    < 'serv . 'com . root, ns, 3600.0, 'ns . 'serv . 'com . root >
    < 'ns . 'serv . 'com . root, a, 3600.0, servDnsAddr >
    ---                                   What should these addresses be?
    < 'tmp0 . 'serv . 'com . root, a, 0.0, 3 . 0 . 1 . 2 >
    < wildcard . 'serv . 'com . root, a, 0.0, 3 . 1 . 1 . 2 >
  .

  --- "SBELT": fallback if there are no known name servers
  op sb : -> ZoneState .
  eq sb = < root ('a . 'root-servers . 'net . root |-> rootDnsAddr) >
  .

  --- Caches
  op resolverCache : -> Cache .
  eq resolverCache =
    cacheEntry(< root, ns, 3600.0, 'a . 'root-servers . 'net . root >, 1)
    cacheEntry(< 'a . 'root-servers . 'net . root, a, 3600.0, rootDnsAddr >, 1)
    cacheEntry(< 'com . root, ns, 3600.0, 'ns . 'com . root >, 1)
    cacheEntry(< 'ns . 'com . root, a, 3600.0, tldDnsAddr >, 1)
    cacheEntry(< 'pwnd . 'com . root, ns, 3600.0, 'ns . 'pwnd . 'com . root >, 1)
    cacheEntry(< 'ns . 'pwnd . 'com . root, a, 3600.0, authDnsAddr >, 1)
    cacheEntry(< 'internet . 'com . root, ns, 3600.0, 'ns . 'internet . 'com . root >, 1)
    cacheEntry(< 'ns . 'internet . 'com . root, a, 3600.0, authDnsAddr >, 1)
    cacheEntry(< 't1 . 'pwnd . 'com . root, ns, 3600.0, 'ns . 't1 . 'pwnd . 'com . root >, 1)
    cacheEntry(< 'ns . 't1 . 'pwnd . 'com . root, a, 3600.0, serverIodineServer4Addr >, 1)
    cacheEntry(< 'corp1 . 'com . root, ns, 3600.0, 'ns . 'corp1 . 'com . root >, 1)
    cacheEntry(< 'ns . 'corp1 . 'com . root, a, 3600.0, corp1DnsAddr >, 1)
    cacheEntry(< 'corp2 . 'com . root, ns, 3600.0, 'ns . 'corp2 . 'com . root >, 1)
    cacheEntry(< 'ns . 'corp2 . 'com . root, a, 3600.0, corp2DnsAddr >, 1)
    cacheEntry(< 'corp3 . 'com . root, ns, 3600.0, 'ns . 'corp3 . 'com . root >, 1)
    cacheEntry(< 'ns . 'corp3 . 'com . root, a, 3600.0, corp3DnsAddr >, 1)
    cacheEntry(< 'corp4 . 'com . root, ns, 3600.0, 'ns . 'corp4 . 'com . root >, 1)
    cacheEntry(< 'ns . 'corp4 . 'com . root, a, 3600.0, corp4DnsAddr >, 1)
    cacheEntry(< 'corp5 . 'com . root, ns, 3600.0, 'ns . 'corp5 . 'com . root >, 1)
    cacheEntry(< 'ns . 'corp5 . 'com . root, a, 3600.0, corp5DnsAddr >, 1)
    cacheEntry(< 'serv . 'com . root, ns, 3600.0, 'ns . 'serv . 'com . root >, 1)
    cacheEntry(< 'ns . 'serv . 'com . root, a, 3600.0, servDnsAddr >, 1)
  .

  ---------------------------------------------------
  --- Addresses
  ---------------------------------------------------
  ops ircClient1Addr ircClient2Addr ircClient3Addr ircClient4Addr : -> Address .
  ops ircClient1UserModelAddr ircClient2UserModelAddr             : -> Address .
  ops ircClient3UserModelAddr ircClient4UserModelAddr             : -> Address .
  ops ircServerAddr s3SrvAddr ircMonitorAddr iodineMonitorAddr    : -> Address .
  ops client1IfaceAddr server1IfaceAddr wtClient1Addr wtProxy1Addr  : -> Address .
  ops wtClient1NetClientAddr wtProxy1NetServerAddr                  : -> Address .
  ops client2IfaceAddr server2IfaceAddr : -> Address .
  ops obfs4Client2Addr obfs4Server2Addr : -> Address .
  ops obfs4Client2NetClientAddr obfs4Server2NetServerAddr : -> Address .
  ops client3IfaceAddr server3IfaceAddr                       : -> Address .
  ops umac3Addr cmac3Addr pua3Addr sdkac3Addr                 : -> Address .
  ops umas3Addr cmas3Addr aha3Addr sdkas3Addr                 : -> Address .
  ops skyhookClient3NetClientAddr : -> Address .
  ops skyhookServer3NetClientAddr : -> Address .
  ops skyhookNetServerAddr : -> Address .
  ops client4IfaceAddr serverIface4Addr                                  : -> Address .
  ops sendApp4Addr iodineClient4Addr rcvApp4Addr serverIodineServer4Addr : -> Address .
  ops iodineClient4NetClientAddr iodineServer4NetServerAddr              : -> Address .
  ops ircClient5Addr ircClient5UserModelAddr client5IfaceAddr server5IfaceAddr : -> Address .
  ops umac5Addr cmac5Addr mcac5Addr edac5Addr : -> Address .
  ops umas5Addr cmas5Addr mcas5Addr edas5Addr : -> Address .
  ops mastodonClient5NetClientAddr mastodonServer5NetClientAddr : -> Address .
  ops masNetServerAddr : -> Address .
  ops masSrvAddr : -> Address .
  ops corp1DnsAddr corp2DnsAddr corp3DnsAddr corp4DnsAddr corp5DnsAddr  : -> Address .
  ops servDnsAddr                                                       : -> Address .
  ops publicDnsAddr rootDnsAddr comDnsAddr tldDnsAddr authDnsAddr       : -> Address .

  eq publicDnsAddr  = a(dnsN, dns, dns, srv, 0) .
  *** Carolyn: This is probably correct, I imagine it should not be a dnsN; what should it be?
  eq rootDnsAddr    = a(dnsN, dns, dns, srv, 0) .
  *** Carolyn: This is probably correct, I imagine it should not be a dnsN; what should it be?
  eq comDnsAddr     = a(dnsN, dns, dns, srv, 0) .
  *** Carolyn: This is probably correct, I imagine it should not be a dnsN; what should it be?
  eq tldDnsAddr     = a(dnsN, dns, dns, srv, 0) .
  *** Carolyn: This is probably correct, I imagine it should not be a dnsN; what should it be?
  eq authDnsAddr    = a(dnsN, dns, dns, srv, 0) .
  eq ircServerAddr  = a(srvN, srv, irc, srv, 0) .

  --- Webtunnel / Client 1
  eq ircClient1Addr           = a(cl[1], hcs, irc, cl, 1) .
  eq ircClient1UserModelAddr  = a(cl[1], hcs, irc, um, 1) .
  eq client1IfaceAddr         = a(cl[1], hcs, irc, if, 1) .
  eq server1IfaceAddr         = a(srvN[1], hcs, irc, if, 1) .
  eq wtClient1Addr            = a(cl[1], hcs, wt, cl, 1) .
  eq wtProxy1Addr             = a(srvN[1], hcs, wt, srv, 1) .
  eq wtClient1NetClientAddr   = a(cl[1], tcp, wt, cl, 1) .
  eq wtProxy1NetServerAddr    = a(srvN[1], tcp, wt, srv, 1) .

  --- Obfs4 / Client 2
  eq ircClient2Addr             = a(cl[2], hcs, irc, cl, 1) .
  eq ircClient2UserModelAddr    = a(cl[2], hcs, irc, um, 1) .
  eq client2IfaceAddr           = a(cl[2], hcs, irc, if, 1) .
  eq server2IfaceAddr           = a(srvN[2], hcs, irc, if, 1) .
  eq obfs4Client2Addr           = a(cl[2], hcs, obfs, cl, 1) .
  eq obfs4Server2Addr           = a(srvN[2], hcs, obfs, srv, 1) .
  eq obfs4Client2NetClientAddr  = a(cl[2], tcp, obfs, cl, 1) .
  eq obfs4Server2NetServerAddr  = a(srvN[2], tcp, obfs, srv, 1) .

  --- Skyhook / Client 3
  eq ircClient3Addr               = a(cl[3], hcs, irc, cl, 1) .
  eq ircClient3UserModelAddr      = a(cl[3], hcs, irc, um, 1) .
  eq client3IfaceAddr             = a(cl[3], hcs, irc, if, 1) .
  eq server3IfaceAddr             = a(srvN[3], hcs, irc, if, 1) .
  eq umac3Addr                    = a(cl[3], hcs, sky, um, 1) .
  eq cmac3Addr                    = a(cl[3], hcs, sky, cm, 1) .
  eq pua3Addr                     = a(cl[3], hcs, sky, pu, 1) .
  eq sdkac3Addr                   = a(cl[3], hcs, sky, dl, 1) .
  eq umas3Addr                    = a(srvN[3], hcs, sky, um, 1) .
  eq cmas3Addr                    = a(srvN[3], hcs, sky, cm, 1) .
  eq aha3Addr                     = a(srvN[3], hcs, sky, ah, 1) .
  eq sdkas3Addr                   = a(srvN[3], hcs, sky, dl, 1) .
  eq skyhookClient3NetClientAddr  = a(cl[3], tcp, sky, cl, 1) .
  eq skyhookServer3NetClientAddr  = a(srvN[3], tcp, sky, cl, 1) .
  eq skyhookNetServerAddr         = a(srvN[3], tcp, sky, srv, 0) .
  eq s3SrvAddr                    = a(minN, srv, min, srv, 0) .

  --- Iodine / Client 4
  eq ircClient4Addr             = a(cl[4], hcs, irc, cl, 1) .
  eq ircClient4UserModelAddr    = a(cl[4], hcs, irc, um, 1) .
  eq client4IfaceAddr           = a(cl[4], hcs, irc, if, 1) .
  eq serverIface4Addr           = a(srvN[4], hcs, irc, if, 1) .
  eq sendApp4Addr               = a(cl[4], hcs, iod, app, 1) .
  eq iodineClient4Addr          = a(cl[4], hcs, iod, cl, 1) .
  eq rcvApp4Addr                = a(srvN[4], hcs, iod, app, 1) .
  eq serverIodineServer4Addr    = a(srvN[4], hcs, iod, iodSrv, 1) .
  eq iodineClient4NetClientAddr = a(cl[4], tcp, iod, cl, 1) .
  eq iodineServer4NetServerAddr = a(srvN[4], tcp, iod, srv, 1) .

  --- Mastodon / Client 5
  eq ircClient5Addr               = a(cl[5], hcs, irc, cl, 1) .
  eq ircClient5UserModelAddr      = a(cl[5], hcs, irc, um, 1) .
  eq client5IfaceAddr             = a(cl[5], hcs, irc, if, 1) .
  eq server5IfaceAddr             = a(srvN[5], hcs, irc, if, 1) .
  eq umac5Addr                    = a(cl[5], hcs, mas, um, 1) .
  eq cmac5Addr                    = a(cl[5], hcs, mas, cm, 1) .
  eq mcac5Addr                    = a(cl[5], hcs, mas, mc, 1) .
  eq edac5Addr                    = a(cl[5], hcs, mas, ed, 1) .
  eq umas5Addr                    = a(srvN[5], hcs, mas, um, 1) .
  eq cmas5Addr                    = a(srvN[5], hcs, mas, cm, 1) .
  eq mcas5Addr                    = a(srvN[5], hcs, mas, mc, 1) .
  eq edas5Addr                    = a(srvN[5], hcs, mas, ed, 1) .
  eq mastodonClient5NetClientAddr = a(cl[5], tcp, mas, cl, 1) .
  eq mastodonServer5NetClientAddr = a(srvN[5], tcp, mas, cl, 1) .
  eq masNetServerAddr             = a(masN, tcp, mas, srv, 0) .
  eq masSrvAddr                   = a(masN, srv, mas, srv, 0) .
  ---------------------------------------------------
  --- Link model parameters
  ---------------------------------------------------

  eq transport(any:Address) = tcp(any:Address) .
  **** tcp actors
  eq transport(a(minN, srv, min, srv, 0))   = tcp(a(minN, srv, min, srv, 0)) .
  eq transport(a(cl[1], hcs, sky, cl, 1))   = tcp(a(cl[1], hcs, sky, cl, 1)) .
  eq transport(a(srvN[1], hcs, sky, cl, 1)) = tcp(a(srvN[1], hcs, sky, cl, 1)) .
  eq transport(a(cl[2], hcs, sky, cl, 1))   = tcp(a(cl[2], hcs, sky, cl, 1)) .
  eq transport(a(srvN[2], hcs, sky, cl, 1)) = tcp(a(srvN[2], hcs, sky, cl, 1)) .
  eq transport(a(cl[3], hcs, sky, cl, 1))   = tcp(a(cl[3], hcs, sky, cl, 1)) .
  eq transport(a(srvN[3], hcs, sky, cl, 1)) = tcp(a(srvN[3], hcs, sky, cl, 1)) .
  eq transport(a(cl[4], hcs, sky, cl, 1))   = tcp(a(cl[4], hcs, sky, cl, 1)) .
  eq transport(a(srvN[4], hcs, sky, cl, 1)) = tcp(a(srvN[4], hcs, sky, cl, 1)) .
  eq transport(a(cl[5], hcs, sky, cl, 1))   = tcp(a(cl[5], hcs, sky, cl, 1)) .
  eq transport(a(srvN[5], hcs, sky, cl, 1)) = tcp(a(srvN[5], hcs, sky, cl, 1)) .

  **** udp actors
  eq transport(a(dnsN, dns, dns, srv, 0))   = udp(a(dnsN, dns, dns, srv, 0)) .
  eq transport(a(cl[1], dns, dns, cl, 0))   = udp(a(cl[1], dns, dns, cl, 0)) .
  eq transport(a(cl[2], dns, dns, cl, 0))   = udp(a(cl[2], dns, dns, cl, 0)) .
  eq transport(a(cl[3], dns, dns, cl, 0))   = udp(a(cl[3], dns, dns, cl, 0)) .
  eq transport(a(cl[4], dns, dns, cl, 0))   = udp(a(cl[4], dns, dns, cl, 0)) .
  eq transport(a(cl[5], dns, dns, cl, 0))   = udp(a(cl[5], dns, dns, cl, 0)) .
  eq transport(a(srvN, dns, dns, cl, 0))    = udp(a(srvN, dns, dns, cl, 0)) .

  vars dt : Float .
  vars icAddr isAddr ifsAddr : Address .
  vars room : String .
  op mkJoin : Float String Address Address Address -> ScheduleMsg .
  eq mkJoin(dt,room,icAddr, isAddr, ifsAddr) =
       [dt,
       (to isAddr from ifsAddr :
        JoinChannel(makeIrcChannelName(room), icAddr )),
        0]
  .

  op LinkType-TCP-4stateLoss : -> AttributeSet .
  eq LinkType-TCP-4stateLoss = 
  (4stateLoss: 
     (p13: 0.0,
      p31: 1.0,          
      p32: 0.0,          
      p23: 0.0,         
      p14: 0.0,          
      oneWayDelay: 0.01) 
  ) .
  op LinkType-Dns : -> AttributeSet .
  eq LinkType-Dns = 
  (delayStd:  0.0),
  (delayType: "Constant"),
  (delayMean: 0.),
  (delayConst: 0.001),
  (noiseMin: 0.),
  (noiseMax: 0.00001),
  (dropP: 0.),
  (canDrop: false),
  (4stateLoss: 
     (p13: 0.0,
      p31: 1.0,          
      p32: 0.0,          
      p23: 0.0,         
      p14: 0.0,          
      oneWayDelay: 0.01) 
  ) .

  eq LinkData =
    --- Client 1 (Webtunnel) Links
    aaa(wtClient1Addr, wtProxy1Addr,  LinkType-TCP-4stateLoss)
    aaa(wtProxy1Addr,  wtClient1Addr, LinkType-TCP-4stateLoss)
    
    --- Client 2 (OBFS4) Links
    aaa(obfs4Client2Addr, obfs4Server2Addr, LinkType-TCP-4stateLoss)
    aaa(obfs4Server2Addr, obfs4Client2Addr, LinkType-TCP-4stateLoss)

    --- Client 3 (Skyhook) Links
    aaa(s3SrvAddr, sdkac3Addr, LinkType-TCP-4stateLoss)
    aaa(s3SrvAddr, sdkas3Addr, LinkType-TCP-4stateLoss)
    aaa(sdkac3Addr, s3SrvAddr, LinkType-TCP-4stateLoss)
    aaa(sdkas3Addr, s3SrvAddr, LinkType-TCP-4stateLoss) 
    
    --- Client 4 (Iodine) Links
    aaa(serverIodineServer4Addr, iodineClient4Addr, LinkType-TCP-4stateLoss)
    aaa(iodineClient4Addr, serverIodineServer4Addr, LinkType-TCP-4stateLoss) 
    
    --- Client 5 (Mastodon) Links
    aaa(masSrvAddr, mcac5Addr, LinkType-TCP-4stateLoss)
    aaa(masSrvAddr, mcas5Addr, LinkType-TCP-4stateLoss)
    aaa(mcac5Addr, masSrvAddr, LinkType-TCP-4stateLoss)
