op advAddr : -> Address .
op advActor : -> Actor .
eq advActor = mkAdversaryCp3(advAddr) .

************** actor defns
***** aliceIrc
eq ircaAct    = mkIrcClient-v2(ircaAddr, ifaceACAddr, "alice") .
eq ircaUserModel = mkIrcUMV2Actor(ircaUserModelAddr, "irc-test", ircaAddr) .
eq ifaceACAct = mkIrcByteSeqIface(ifaceACAddr,
                                  ircaAddr,
                                  cmacAddr,
                                  cmacAddr) .

**** alice client rb endpoint
eq umacAct  = mkUMactor(umacAddr,
                        mastodon-client-config-mastodon-bidi-ma,
                        cmacAddr)
.
eq cmacAct  = mkCMSndRcvActor(cmacAddr,
                              edacAddr,
                              mcacAddr,
                              ifaceACAddr, 
                              "client0",
                              "server0")
.
eq mcacAct  = makeMastodonClient(mcacAddr, masSrvAddr, cmacAddr) .
eq edacAct  = makeDestiniActor(edacAddr, ed-images) .

eq ifaceASAct = mkIrcByteSeqIface(ifaceASAddr,
                                  ircSrvAddr, 
                                  cmasAddr,
                                  cmasAddr)
.
eq umasAct  = mkUMactor(umasAddr, 
                        mastodon-client-config-mastodon-bidi-ma,
                        cmasAddr)
.
eq cmasAct  = mkCMSndRcvActor(cmasAddr,
                              edasAddr,
                              mcasAddr,
                              ifaceASAddr, ---- sndAddr
                              "server0",
                              "client0")
.
eq mcasAct  = makeMastodonClient(mcasAddr, masSrvAddr, cmasAddr) .
eq edasAct  = makeDestiniActor(edasAddr, ed-images) .

eq aliceNetClient = makeNetClient(aliceNetClientAddr,
                                  masSrvAddr,
                                  mcacAddr,
                                  true,
                                  nullAddr,
                                  nullName)
.
eq serverAliceNetClient = makeNetClient(serverAliceNetClientAddr,
                                        masSrvAddr,
                                        mcasAddr,
                                        true,
                                        nullAddr,
                                        nullName)
.
********************************
*** bob
eq ircbAct  = mkIrcClient-v2(ircbAddr, ifaceBCAddr, "bob") .
eq ircbUserModel = mkIrcUMV2Actor(ircbUserModelAddr, "irc-test", ircbAddr) .

eq ifaceBCAct = mkIrcByteSeqIface(ifaceBCAddr,
                                  ircbAddr,
                                  cmbcAddr,
                                  cmbcAddr)
.
*** bob client  rbendpoint
eq umbcAct  = mkUMactor(umbcAddr, 
                        mastodon-client-config-mastodon-bidi-ma,
                        cmbcAddr)
.
eq cmbcAct  = mkCMSndRcvActor(cmbcAddr,
                              edbcAddr,
                              mcbcAddr,
                              ifaceBCAddr, ---- sndAddr
                              "client1",
                              "server1")
.
eq mcbcAct  = makeMastodonClient(mcbcAddr, masSrvAddr, cmbcAddr) .
eq edbcAct  = makeDestiniActor(edbcAddr, ed-images) .

*** bob server endpoint
eq ifaceBSAct = mkIrcByteSeqIface(ifaceBSAddr,
                                  ircSrvAddr, 
                                  cmbsAddr,
                                  cmbsAddr)
.
eq umbsAct  = mkUMactor(umbsAddr, 
                        mastodon-client-config-mastodon-bidi-ma,
                        cmbsAddr)
.
eq cmbsAct  = mkCMSndRcvActor(cmbsAddr,
                              edbsAddr,
                              mcbsAddr,
                              ifaceBSAddr, ---- sndAddr
                              "server1",
                              "client1")
.
eq mcbsAct  = makeMastodonClient(mcbsAddr, masSrvAddr, cmbsAddr) .
eq edbsAct  = makeDestiniActor(edbsAddr, ed-images) .

eq bobNetClient = makeNetClient(bobNetClientAddr,
                                masSrvAddr,
                                mcbcAddr,
                                true,
                                nullAddr,
                                nullName)
.
eq serverBobNetClient = makeNetClient(serverBobNetClientAddr,
                                      masSrvAddr,
                                      mcbsAddr,
                                      true,
                                      nullAddr,
                                      nullName)
.

******** global actors
eq masSrvAct = makeMastodonServer(masSrvAddr) .
eq ircSrvAct = mkIrcServer(ircSrvAddr) .

eq masNetServer = makeNetServer(masNetServerAddr, masSrvAddr) .
eq ircMonitorAct = mkIrcMonitor(ircMonitorAddr)
.

eq transport(any:Address) = tcp(any:Address) .

op LinkParams : -> AttributeSet .
eq LinkParams =
(4stateLoss: (p13: 0.0,
                p31: 1.0,
                p32: 0.0,
                p23: 0.0,
                p14: 0.0,
                oneWayDelay: 0.01))
.

eq LinkData =
  aaa(masSrvAddr, mcacAddr, LinkParams)
  aaa(masSrvAddr, mcasAddr, LinkParams)
  aaa(masSrvAddr, mcbcAddr, LinkParams)
  aaa(masSrvAddr, mcbsAddr, LinkParams)
 
  aaa(mcacAddr, masSrvAddr, LinkParams)
  aaa(mcasAddr, masSrvAddr, LinkParams)
  aaa(mcbcAddr, masSrvAddr, LinkParams)
  aaa(mcbsAddr, masSrvAddr, LinkParams)

  aaa(masSrvAddr, IXP-DEFAULT-ADDR, LinkParams)
  aaa(IXP-DEFAULT-ADDR, masSrvAddr, LinkParams)

  aaa(IXP-DEFAULT-ADDR, mcacAddr, LinkParams)
  aaa(IXP-DEFAULT-ADDR, mcasAddr, LinkParams)
  aaa(IXP-DEFAULT-ADDR, mcbcAddr, LinkParams)
  aaa(IXP-DEFAULT-ADDR, mcbsAddr, LinkParams)

  aaa(mcacAddr, IXP-DEFAULT-ADDR, LinkParams)
  aaa(mcasAddr, IXP-DEFAULT-ADDR, LinkParams)
  aaa(mcbcAddr, IXP-DEFAULT-ADDR, LinkParams)
  aaa(mcbsAddr, IXP-DEFAULT-ADDR, LinkParams)
.

vars dt : Float .
vars icAddr isAddr ifsAddr : Address .
vars room : String .
op mkJoin : Float String Address Address Address -> ScheduleMsg .
eq mkJoin(dt,room,icAddr, isAddr, ifsAddr) =
    [dt,
    (to isAddr from ifsAddr :
    JoinChannel(makeIrcChannelName(room), icAddr )),
    0]
.

op initState : Nat -> Config .
eq initState(j) =
  rCtr(j + 8)
******* alice 
  ircaAct ircaUserModel
*** alice client endpoint
  ifaceACAct
  umacAct cmacAct mcacAct edacAct
**** alice server endpoint
  ifaceASAct
  umasAct cmasAct mcasAct edasAct 
*** Net clients
  aliceNetClient
  serverAliceNetClient 
******* bob
  ircbAct ircbUserModel
**** bob client endpoint
  ifaceBCAct
  umbcAct cmbcAct mcbcAct edbcAct
***** bob server endpoint
  ifaceBSAct
  umbsAct cmbsAct mcbsAct edbsAct 
*** Net clients
  bobNetClient
  serverBobNetClient
**** global
  ircSrvAct
  masSrvAct 
  ircMonitorAct
*** Net servers
  masNetServer
  advActor

mkJoin(1.0, "#chat", ircaAddr, ircSrvAddr, ifaceASAddr)
mkJoin(1.1, "#general", ircaAddr, ircSrvAddr, ifaceASAddr)
mkJoin(1.2, "#random", ircaAddr, ircSrvAddr, ifaceASAddr)

mkJoin(1.3, "#chat", ircbAddr, ircSrvAddr, ifaceBSAddr)
mkJoin(1.4, "#general", ircbAddr, ircSrvAddr, ifaceBSAddr)
mkJoin(1.5, "#random", ircbAddr, ircSrvAddr, ifaceBSAddr)

**** start mastodon underlying user models
  [1.0 + genRandomX(j, 0.0, 0.0001), (to umacAddr from umacAddr : actionR("ok")), 0]
  [1.0 + genRandomX(s s j, 0.0, 0.0001), (to umasAddr from umasAddr : actionR("ok")), 0]
  [1.0 + genRandomX(s s s j, 0.0, 0.0001), (to umbcAddr from umbcAddr : actionR("ok")), 0]
  [1.0 + genRandomX(s s s s j, 0.0, 0.0001), (to umbsAddr from umbsAddr : actionR("ok")), 0]
  
**** start alice
  [2.1, to ircaUserModelAddr from ircaUserModelAddr : burstDelayTO, 0]
**** start bob
  [2.2, to ircbUserModelAddr from ircbUserModelAddr : burstDelayTO, 0]
  

.

op slimit : -> Float .
eq slimit = 300.0 .

op initConfig : -> Config .
rl[init]: initConfig 
   => run({0.0 | nil} initState(counter), slimit) .

endm

****red "Alice,Bob join room1, Alice,Bob send 3 texts ircMonitor" .
****eof
set print attribute on .
rew initConfig .
q
eof

  
