vars j : Nat .

eq encOH(fsize:Nat,ksize:Nat)  = 0 .
eq noiseMin(msg:Msg) = 0.001 .

***** Global constants  
**** the user model database
eq MAModelMap = ("irc-test" |-> irc-mamodel-v2 ) .

*** for the default case
eq noiseMax(msg:Msg) = 0.00001 .

op ed-images : -> ByteSeqL .
eq ed-images =
     image(1, 3779, 500)
  :: image(2, 2405, 1000)
  :: image(3, 36861, 1000)
  :: image(4, 25377, 500)
  :: image(5, 2440, 300)
  :: image(6, 1275, 300)
  :: image(7, 7710, 1000)
  :: image(8, 3577, 500)
  :: image(9, 3415, 300)
  :: image(10, 74123, 600)
.

ops irccAddr : -> Address .
**** addresses
*** alice
ops ircaAddr : -> Address .
ops ircaUserModelAddr : -> Address .
**** alice channel interfaces
ops ifaceACAddr ifaceASAddr : -> Address .
*** client endpoint ac
ops umacAddr  cmacAddr mcacAddr edacAddr : -> Address .
*** server endpoint as
ops umasAddr  cmasAddr mcasAddr edasAddr : -> Address .
*** Net clients
ops aliceNetClientAddr  serverAliceNetClientAddr  : -> Address .
*** bob
ops ircbAddr : -> Address .
ops ircbUserModelAddr : -> Address .
**** bobs channel endpoint interfaces
ops ifaceBCAddr ifaceBSAddr : -> Address .
*** client endpointl  ..bc.. ..bs..
ops umbcAddr  cmbcAddr mcbcAddr edbcAddr : -> Address .
*** server endpoint
ops umbsAddr  cmbsAddr mcbsAddr edbsAddr : -> Address .
*** Net clients
ops bobNetClientAddr  serverBobNetClientAddr  : -> Address .
ops ircSrvAddr masSrvAddr : -> Address .
ops ircMonitorAddr : -> Address .
*** Net servers
*** Facing IRC clients
op masNetServerAddr : -> Address .
eq masNetServerAddr = a(masN,tcp,mas,srv,0) .

eq irccAddr = a(cl[3],hcs,irc,cl,1) .
eq ircaAddr = a(cl[1],hcs,irc,cl,1) .
eq ircaUserModelAddr = a(cl[1],hcs,irc,um,1) .
eq ifaceACAddr = a(cl[1],hcs,irc,if,1) .
eq ifaceASAddr = a(srvN[1],hcs,irc,if,1) .
eq umacAddr = a(cl[1],hcs,mas,um,1) .
eq cmacAddr = a(cl[1],hcs,mas,cm,1) .
eq mcacAddr = a(cl[1],hcs,mas,mc,1) .
eq edacAddr = a(cl[1],hcs,mas,ed,1) .
eq umasAddr = a(srvN[1],hcs,mas,um,1) .
eq cmasAddr = a(srvN[1],hcs,mas,cm,1) .
eq mcasAddr = a(srvN[1],hcs,mas,mc,1) .
eq edasAddr = a(srvN[1],hcs,mas,ed,1) .
eq aliceNetClientAddr = a(cl[1],tcp,mas,cl,1) .
eq serverAliceNetClientAddr = a(srvN[1],tcp,mas,cl,1) .

eq ircbAddr = a(cl[2],hcs,irc,cl,1) .
eq ircbUserModelAddr = a(cl[2],hcs,irc,um,1) .
eq ifaceBCAddr = a(cl[2],hcs,irc,if,1) .
eq ifaceBSAddr = a(srvN[2],hcs,irc,if,1) .
eq umbcAddr = a(cl[2],hcs,mas,um,1) .
eq cmbcAddr = a(cl[2],hcs,mas,cm,1) .
eq mcbcAddr = a(cl[2],hcs,mas,mc,1) .
eq edbcAddr = a(cl[2],hcs,mas,ed,1) .
eq umbsAddr = a(srvN[2],hcs,mas,um,1) .
eq cmbsAddr = a(srvN[2],hcs,mas,cm,1) .
eq mcbsAddr = a(srvN[2],hcs,mas,mc,1) .
eq edbsAddr = a(srvN[2],hcs,mas,ed,1) .
eq bobNetClientAddr = a(cl[2],tcp,mas,cl,1) .
eq serverBobNetClientAddr = a(srvN[2],tcp,mas,cl,1) .

eq ircSrvAddr = a(srvN,srv,irc,srv,0) .
eq masSrvAddr = a(masN,srv,mas,srv,0) .

