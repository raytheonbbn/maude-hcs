eq umacAddr = a(cl[1],hcs,sky,um,1) .
eq cmacAddr = a(cl[1],hcs,sky,cm,1) .
eq puaAddr = a(cl[1],hcs,sky,pu,1) .
eq sdkacAddr = a(cl[1],hcs,sky,cl,1) .
--- tcp net cnx
eq aliceNetClientAddr = a(cl[1],tcp,min,cl,1) .

  
 **** clientNet2 bob
 eq ircbAddr = a(cl[2],hcs,irc,cl,1) .
