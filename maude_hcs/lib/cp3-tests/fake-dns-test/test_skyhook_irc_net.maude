  aaa(a(srvN,dns,dns,cl,0),IXP-DEFAULT-ADDR,LinkType-2)

  aaa(a(dnsN,dns,dns,srv,0) ,IXP-DEFAULT-ADDR,LinkType-2)
  aaa(IXP-DEFAULT-ADDR,a(dnsN,dns,dns,srv,0) ,LinkType-2)
.                               
 
