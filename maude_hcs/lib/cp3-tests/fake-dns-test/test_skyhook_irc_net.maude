******* fake DNS actors

**** dnsFakes
ops corpAFwd corpBFwd corpSFwd pubRsv : -> Actor .
op pubRsvAddr : -> Address .
eq pubRsvAddr = a(dnsN,dns,dns,srv,0) .

eq corpAFwd = mkFakeFwd(a(cl[1],dns,dns,cl,0), pubRsvAddr) .
eq corpBFwd = mkFakeFwd(a(cl[2],dns,dns,cl,0), pubRsvAddr) .
eq corpSFwd = mkFakeFwd(a(srvN,dns,dns,cl,0), pubRsvAddr) .
  
eq pubRsv = mkFakeRsv(pubRsvAddr) .
  
**** the associated network actors
ops corpANetClient corpBNetClient corpSNetClient
     pubRsvNetClient : -> Actor .

eq corpANetClient =
    makeNetClient(a(cl[1],udp,dns,cl,0), pubRsvAddr,
                  a(cl[1],dns,dns,cl,0),true) .
eq corpBNetClient =
    makeNetClient(a(cl[2],udp,dns,cl,0), pubRsvAddr,
                  a(cl[2],dns,dns,cl,0),true) .

eq corpSNetClient =
    makeNetClient(a(srvN,udp,dns,cl,0), pubRsvAddr,
                  a(srvN,dns,dns,cl,0),true) .

eq pubRsvNetClient =
    makeNetClient(a(dnsN,udp,dns,cl,0), pubRsvAddr,
                  pubRsvAddr,true) .
  
                
------------ end actors               
