      = tcp(a(minN,srv,min,srv,0)) .
eq transport(a(cl[1],hcs,sky,cl,1))
      = tcp(a(cl[1],hcs,sky,cl,1)) .
eq transport(a(srvN[1],hcs,sky,cl,1) )
      = tcp(a(srvN[1],hcs,sky,cl,1) ) .
eq transport(a(cl[2],hcs,sky,cl,1)) 
      = tcp(a(cl[2],hcs,sky,cl,1)) .
eq transport(a(srvN[2],hcs,sky,cl,1) ) 
    = tcp(a(srvN[2],hcs,sky,cl,1) ) .

**** udp actors
eq transport(a(dnsN,dns,dns,srv,0))  = 
            udp(a(dnsN,dns,dns,srv,0)) .
eq transport(a(cl[1],dns,dns,cl,0))
         = udp(a(cl[1],dns,dns,cl,0)) .
eq transport(a(cl[2],dns,dns,cl,0))
         = udp(a(cl[2],dns,dns,cl,0)) .
eq transport(a(srvN,dns,dns,cl,0))
         = udp(a(srvN,dns,dns,cl,0)) .



  op LinkType-2 : -> AttributeSet .
  eq LinkType-2 = 
    (delayStd: 0.),
    (delayType: "Constant"),
    (delayMean: 0.),
    (delayConst: 0.005),
    (noiseMin: 0.),
    (noiseMax: 0.00001),
    (dropP: 0.),
    (canDrop: false)
    .

  op LinkType-2x : -> AttributeSet .
  eq LinkType-2x = 
    (delayStd: 0.),
    (delayType: "Constant"),
    (delayMean: 0.),
    (delayConst: 0.0025),
    (noiseMin: 0.),
    (noiseMax: 0.00001),
    (dropP: 0.),
    (canDrop: false)
    .

  op LinkType-TCP : -> AttributeSet .
  eq LinkType-TCP = 
  (4stateLoss: 
     (p13: 0.0,
      p31: 1.0,          
      p32: 0.0,          
      p23: 0.0,         
      p14: 0.0,          
      oneWayDelay: 0.01) 
  ) .

  op LinkType-TCPx : -> AttributeSet .
  eq LinkType-TCPx = 
  (4stateLoss: 
     (p13: 0.0,
      p31: 1.0,          
      p32: 0.0,          
      p23: 0.0,         
      p14: 0.0,          
      oneWayDelay: 0.005) 
  ) .

eq LinkData =
  aaa(s3SrvAddr,sdkacAddr,LinkType-TCP)
  aaa(s3SrvAddr,sdkasAddr,LinkType-TCP)
  aaa(s3SrvAddr,sdkbcAddr,LinkType-TCP)
  aaa(s3SrvAddr,sdkbsAddr,LinkType-TCP)
 
  aaa(s3SrvAddr,IXP-DEFAULT-ADDR,LinkType-TCPx)
  aaa(IXP-DEFAULT-ADDR,s3SrvAddr,LinkType-TCPx)

  aaa(IXP-DEFAULT-ADDR,sdkacAddr,LinkType-TCPx)
  aaa(IXP-DEFAULT-ADDR,sdkasAddr,LinkType-TCPx)
  aaa(IXP-DEFAULT-ADDR,sdkbcAddr,LinkType-TCPx)
  aaa(IXP-DEFAULT-ADDR,sdkbsAddr,LinkType-TCPx)
 
  aaa(sdkacAddr,s3SrvAddr,LinkType-TCP)
  aaa(sdkasAddr,s3SrvAddr,LinkType-TCP)
  aaa(sdkbcAddr,s3SrvAddr,LinkType-TCP)
  aaa(sdkbsAddr,s3SrvAddr,LinkType-TCP)

  aaa(sdkacAddr,IXP-DEFAULT-ADDR,LinkType-TCPx)
  aaa(sdkasAddr,IXP-DEFAULT-ADDR,LinkType-TCPx)
  aaa(sdkbcAddr,IXP-DEFAULT-ADDR,LinkType-TCPx)
  aaa(sdkbsAddr,IXP-DEFAULT-ADDR,LinkType-TCPx)

  **** udp links
  aaa(a(dnsN,dns,dns,srv,0),a(cl[1],dns,dns,cl,0),LinkType-2)
  aaa(a(dnsN,dns,dns,srv,0) ,a(cl[2],dns,dns,cl,0),LinkType-2)
  aaa(a(dnsN,dns,dns,srv,0) ,a(srvN,dns,dns,cl,0),LinkType-2)

  aaa(IXP-DEFAULT-ADDR,a(cl[1],dns,dns,cl,0),LinkType-2)
  aaa(IXP-DEFAULT-ADDR,a(cl[2],dns,dns,cl,0),LinkType-2)
  aaa(IXP-DEFAULT-ADDR,a(srvN,dns,dns,cl,0),LinkType-2)

  aaa(a(cl[1],dns,dns,cl,0),a(dnsN,dns,dns,srv,0) ,LinkType-2)
  aaa(a(cl[2],dns,dns,cl,0),a(dnsN,dns,dns,srv,0) ,LinkType-2)
  aaa(a(srvN,dns,dns,cl,0),a(dnsN,dns,dns,srv,0) ,LinkType-2)

  aaa(a(cl[1],dns,dns,cl,0),IXP-DEFAULT-ADDR,LinkType-2)
