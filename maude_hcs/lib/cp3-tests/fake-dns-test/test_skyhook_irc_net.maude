eq s3NetServer = makeNetServer(s3NetServerAddr,
                                s3SrvAddr)
.

**** makeIrcServer takes an unused address arg
eq ircSrvAct =
    < ircSrvAddr : IrcServer |
        thisAddr: ircSrvAddr,
        channelMap: emptyNameClientsMap,
        clientTimestampMap: emptyClientTimestampMap,
        clientAddressMap: emptyClientAddressMap
    >
  .

eq ircMonitorAct = 
    mkIrcMonitor(ircMonitorAddr) .  

