 pubRsvNetClient 

**** start ahAlice
    [0.001, (to ahaAddr from  ahaAddr : SkyhookStartCmd), 0]
**** start ahBob
    [0.002, (to ahbAddr from ahbAddr : SkyhookStartCmd), 0]

**** start client channel ums
 [0.05, (to a(cl[1], hcs, sky, um, 1) from a(cl[1], hcs, sky, um, 1) : actionR("ok") ),0]
 [0.06, (to a(cl[2], hcs, sky, um, 1) from a(cl[2], hcs, sky, um, 1) : actionR("ok") ),0]

**** start server channel ums
 [0.055, (to a(srvN[1], hcs, sky, um, 1) from a(srvN[1], hcs, sky, um, 1) : actionR("ok") ),0]
 
 [0.065, (to a(srvN[2], hcs, sky, um, 1) from a(srvN[2], hcs, sky, um, 1) : actionR("ok") ),0]
 
***** join chanels
 [1.01, (to ircSrvAddr from ifaceASAddr :
   JoinChannel(makeIrcChannelName("#chat"), ircaAddr)), 0]

 [20.015, (to ircSrvAddr from ifaceBSAddr :
   JoinChannel(makeIrcChannelName("#chat"), ircbAddr)), 0]

 [40.02, (to ircSrvAddr from ifaceASAddr :
   JoinChannel(makeIrcChannelName("#general"), ircaAddr)), 0]

 [60.025, (to ircSrvAddr from ifaceBSAddr :
   JoinChannel(makeIrcChannelName("#general"), ircbAddr)), 0]

 [80.03, (to ircSrvAddr from ifaceASAddr :
   JoinChannel(makeIrcChannelName("#random"), ircaAddr)), 0]

 [100.035, (to ircSrvAddr from ifaceBSAddr :
   JoinChannel(makeIrcChannelName("#random"), ircbAddr)), 0]
    
**** start alice
  [120.1, to ircaUserModelAddr from ircaUserModelAddr : burstDelayTO, 0]
**** start bob
  [120.2, to ircbUserModelAddr from ircbUserModelAddr : burstDelayTO, 0]
.

  eq IRC-STALE-DURATION-S = 140000. [owise] .
  eq IRC-PING-INTV-S = 1200000. [owise]  .

op slimit : -> Float .
eq slimit = 1000000.0 .

