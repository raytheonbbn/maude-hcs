---
--- test_webtunnel_irc.maude
---
--- Scenario: 2 IRC clients (Alice and Bob) communicating with a single
--- IRC server, each via a webtunnel client actor.  A shared webtunnel
--- server proxy terminates both tunnels and bridges traffic to the server.
---
--- Topology:
---
---  .-----------.       .-----------.               .-----------.
---  | IrcClient1|------>| WtClient1 |=====HTTPS====>|           |--------.
---  |  (Alice)  |<------| (alice)   |<=============<|           |        |
---  `-----------'       `-----------'               |           |   .-----------.
---                                                  | WtProxy   |   | IrcServer |
---  .-----------.       .-----------.               |           |   `-----------'
---  | IrcClient2|------>| WtClient2 |=====HTTPS====>|           |        |
---  |  (Bob)    |<------| (bob)     |<=============<|           |<-------'
---  `-----------'       `-----------'               `-----------'
---
--- Timeline:
---   t=0.10  Alice's WtClient initiates tunnel setup
---   t=0.15  Bob's WtClient initiates tunnel setup
---   ~0.46   Tunnels established (link delay + WtConnectOverhead = 0.35s)
---   t=0.50  Alice joins channel #maude-test (sent after tunnels open)
---   t=0.55  Bob joins channel #maude-test
---   t=2.00  Alice sends first IRC message
---   t=4.00  Bob sends first IRC message
---   t=6.00  Alice sends second IRC message
---
--- To run: load this file in Maude, then execute:
---   red initConfig .
---

sload ./webtunnel_prob

set print attribute on .

mod TEST_WEBTUNNEL_IRC is
  pr IRC .
  pr WEBTUNNEL .
  pr IRC_NAMES .

  ---------------------------------------------------
  --- Addresses
  ---------------------------------------------------

  --- IRC layer actors
  ops ircClient1Addr ircClient2Addr : -> Address .  --- Alice, Bob
  op  ircServerAddr                 : -> Address .  --- IRC server

  --- Webtunnel layer actors
  ops wtClient1Addr wtClient2Addr : -> Address .   --- Alice-side, Bob-side
  op  wtProxyAddr                 : -> Address .   --- shared proxy

  ---------------------------------------------------
  --- Link model parameters
  ---
  --- A simple constant-delay, no-drop link for clarity.
  --- Override these equations to add latency or packet loss.
  ---------------------------------------------------
  op LinkParams : -> AttributeSet .
  eq LinkParams =
    (delayStd:    0.),
    (delayType:   "Constant"),
    (delayMean:   0.),
    (delayConst:  0.050),     --- 50 ms one-way delay
    (noiseMin:    0.),
    (noiseMax:    0.00001),
    (dropP:       0.),
    (canDrop:     false)
  .

  eq LinkData =
    --- Webtunnel clients <-> proxy
    aaa(wtClient1Addr, wtProxyAddr,    LinkParams)
    aaa(wtProxyAddr,   wtClient1Addr,  LinkParams)
    aaa(wtClient2Addr, wtProxyAddr,    LinkParams)
    aaa(wtProxyAddr,   wtClient2Addr,  LinkParams)
    --- Proxy <-> IRC server (local / low latency)
    aaa(wtProxyAddr,   ircServerAddr,  LinkParams)
    aaa(ircServerAddr, wtProxyAddr,    LinkParams)
  .

  ---------------------------------------------------
  --- Message schedules
  ---
  --- imd(delaySeconds, room, messageSize)
  --- The delay is relative to the first scheduled send (set via ircMsgSendTime).
  --- Message text is generated by genIrcText(userId, counter, size).
  ---------------------------------------------------
  op aliceMessages : -> IrcMsgDelayList .
  eq aliceMessages =
    imd( 0.000, "#maude-test", 120) ::  --- first message at send-start
    imd( 4.000, "#maude-test", 200)     --- second message 4 s later
  .

  op bobMessages : -> IrcMsgDelayList .
  eq bobMessages =
    imd( 0.000, "#maude-test", 95)      --- one message
  .

  ---------------------------------------------------
  --- Actors
  ---------------------------------------------------

  ops ircClient1 ircClient2 ircServer : -> Actor .
  ops wtClient1 wtClient2 wtProxy     : -> Actor .

  --- IRC clients.  Their raceboatAddr points to the WtClient actor,
  --- which acts as the transparent next-hop toward the IRC server.
  eq ircClient1 =
    mkIrcClient(ircClient1Addr,
                wtClient1Addr,     --- raceboatAddr = WtClient (not server directly)
                "alice",
                aliceMessages)
  .

  eq ircClient2 =
    mkIrcClient(ircClient2Addr,
                wtClient2Addr,     --- raceboatAddr = WtClient
                "bob",
                bobMessages)
  .

  --- Webtunnel client actors.
  --- tlsServerName and upgradePath would be the bridge's public domain
  --- and secret path in a real deployment.
  eq wtClient1 =
    makeWtClient(wtClient1Addr,
                 wtProxyAddr,
                 ircServerAddr,
                 "irc.example.com",   --- TLS SNI
                 "secret/path/v1")    --- HTTP Upgrade path
  .

  eq wtClient2 =
    makeWtClient(wtClient2Addr,
                 wtProxyAddr,
                 ircServerAddr,
                 "irc.example.com",
                 "secret/path/v1")
  .

  --- Shared webtunnel server proxy.
  --- Its raceboatAddr (used by the IRC server for outbound messages) is
  --- wtProxyAddr itself, since the proxy terminates all tunnel connections.
  eq wtProxy =
    makeWtServerProxy(wtProxyAddr, ircServerAddr)
  .

  --- IRC server.  raceboatAddr = wtProxyAddr so all server-originated
  --- messages are delivered to the proxy, which routes them into tunnels.
  eq ircServer =
    makeIrcServer(ircServerAddr, wtProxyAddr)
  .

  ---------------------------------------------------
  --- Initial configuration
  ---------------------------------------------------

  op initState : -> Config .
  eq initState =
    rCtr(0)

    --- Actors
    ircClient1
    ircClient2
    wtClient1
    wtClient2
    wtProxy
    ircServer

    --- Phase 1: Tunnel setup
    --- Alice's WtClient initiates its tunnel.
    [0.10, (to wtClient1Addr from wtClient1Addr : WtStartCmd), 0]
    --- Bob's WtClient initiates its tunnel.
    [0.15, (to wtClient2Addr from wtClient2Addr : WtStartCmd), 0]

    --- Phase 2: Channel join (sent after tunnels should be open).
    --- These go to the WtClient, which wraps them in WtData and forwards.
    --- t=0.50 > 0.15 + 0.050 (link) + 0.35 (WtConnectOverhead) = 0.55
    --- (Using 0.65 to be safely after both tunnels are up.)
    [0.65, (to wtClient1Addr from ircClient1Addr
             : JoinChannel(makeIrcChannelName("maude-test"), ircClient1Addr)), 0]
    [0.70, (to wtClient2Addr from ircClient2Addr
             : JoinChannel(makeIrcChannelName("maude-test"), ircClient2Addr)), 0]

    --- Phase 3: IRC message send timers.
    --- ircMsgSendTime is the internal trigger used by the IRC actor's
    --- message-schedule machinery (from irc_prob.maude).
    [2.00, (to ircClient1Addr from ircClient1Addr : ircMsgSendTime), 0]
    [4.00, (to ircClient2Addr from ircClient2Addr : ircMsgSendTime), 0]
  .

  ---------------------------------------------------
  --- Run parameters
  ---------------------------------------------------
  op limit : -> Float .
  eq limit = 30.0 .    --- simulate 30 simulated seconds

  op initConfig : -> Config .
  eq initConfig = run({0.0 | nil} initState, limit) .

endm

---------------------------------------------------
--- Unit-level rewrite tests
---
--- Because this file imports webtunnel_prob, all rules use timed messages.
--- Unit tests therefore wrap messages in {T, ...} and include rCtr(0).
---------------------------------------------------

--- Test 1: WtClient transitions from Closed -> Connecting on WtStartCmd.
rew rCtr(0)
    wtClient1
    {0.0, (to wtClient1Addr from wtClient1Addr : WtStartCmd)}
.

--- Test 2: WtClient transitions from Connecting -> Open on WtConnected
---         and flushes the queued JoinChannel message.
rew rCtr(0)
    < wtClient1Addr : WtClient |
        thisAddr:        wtClient1Addr,
        serverProxyAddr: wtProxyAddr,
        ircServerAddr:   ircServerAddr,
        ircClientAddr:   ircClient1Addr,
        tlsServerName:   "irc.example.com",
        upgradePath:     "secret/path/v1",
        tunnelState:     Connecting,
        pendingMsgs:     enqueue(emptyQueue,
                           JoinChannel(makeIrcChannelName("maude-test"),
                                       ircClient1Addr))
    >
    {0.0, (to wtClient1Addr from wtProxyAddr : WtConnected)}
.

--- Test 3: WtServerProxy registers a tunnel on WtConnect and schedules WtConnected.
rew rCtr(0)
    wtProxy
    {0.0, (to wtProxyAddr from wtClient1Addr
            : WtConnect("irc.example.com", "secret/path/v1"))}
.

--- Test 4: WtServerProxy forwards a WtData(JoinChannel) from client to IRC server.
rew rCtr(0)
    < wtProxyAddr : WtServerProxy |
        thisAddr:        wtProxyAddr,
        ircServerAddr:   ircServerAddr,
        tunnelClientMap: (makeIrcUserName(wtClient1Addr) ~> ircClient1Addr)
    >
    {0.0, (to wtProxyAddr from wtClient1Addr
            : WtData(JoinChannel(makeIrcChannelName("maude-test"), ircClient1Addr)))}
.

--- Test 5: WtServerProxy routes a PrivMsgRes back through the tunnel to WtClient1.
rew rCtr(0)
    < wtProxyAddr : WtServerProxy |
        thisAddr:        wtProxyAddr,
        ircServerAddr:   ircServerAddr,
        tunnelClientMap: (makeIrcUserName(wtClient1Addr) ~> ircClient1Addr)
    >
    {0.0, (to ircClient1Addr from ircServerAddr
            : PrivMsgRes(makeIrcChannelName("maude-test"),
                         makeIrcUserName(ircClient2Addr),
                         "alice:0:120"))}
.


