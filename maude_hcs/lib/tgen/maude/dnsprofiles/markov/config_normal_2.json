{
    "markov": {
        "single":      {"wait_normal": 1.0},
        "batch":       {"wait_normal": 1.0},
        "wait_normal": {"single": 0.1,"batch": 0.8, "wait_normal": 0.1}
    },
    "actions": {
        "single": {
            "type": "resolve_a"
        },
        "batch": {
            "type": "resolve_a_batch",
            "num_to_resolve": {"random": "uniform","min": 2,"max": 12}
        },
        "wait_normal": {
            "type": "wait",
            "sleep": {"random": "gaussian","mean": 10.0,"std": 5.0,"floor": 1.0},
            "start": true
        }
    },
    "parameters": {
        "model_steps": 1000,
        "domains_file": "testDomains.csv",
        "request_timeout": 5,
        "request_lifetime": 10
    }
}
