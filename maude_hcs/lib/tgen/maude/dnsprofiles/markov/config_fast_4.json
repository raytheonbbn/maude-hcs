{
    "markov": {
        "single":      {"wait_single": 1.0},
        "batch":       {"wait_batch": 1.0},
        "wait_single": {"single": 0.7,"batch": 0.3},
        "wait_batch":  {"single": 0.7,"batch": 0.3}
    },
    "actions": {
        "single": {
            "type": "resolve_a"
        },
        "batch": {
            "type": "resolve_a_batch",
            "num_to_resolve": {"random": "uniform","min": 5,"max": 15}
        },
        "wait_single": {
            "type": "wait",
            "sleep": {"random": "gaussian","mean": 0.5,"std": 0.3,"floor": 0.1},
            "start": true
        },
        "wait_batch": {
            "type": "wait",
            "sleep": {"random": "gaussian","mean": 0.5,"std": 0.1,"floor": 0.1}
        }
    },
    "parameters": {
        "model_steps": 1000,
        "domains_file": "testDomains.csv",
        "request_timeout": 5,
        "request_lifetime": 10
    }
}
