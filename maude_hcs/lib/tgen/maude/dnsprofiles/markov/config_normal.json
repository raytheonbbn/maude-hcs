{
    "markov": {
        "single":      {"single": 0.0,"batch": 0.0,"wait_normal": 1.0},
        "batch":       {"single": 0.0,"batch": 0.0,"wait_normal": 1.0},
        "wait_normal": {"single": 0.35,"batch": 0.35,"wait_normal": 0.3}
    },
    "actions": {
        "single": {
            "type": "resolve_a"
        },
        "batch": {
            "type": "resolve_a_batch",
            "num_to_resolve": {"random": "uniform","min": 2,"max": 12},
            "start": true
        },
        "wait_normal": {
            "type": "wait",
            "sleep": {"random": "gaussian","mean": 10.0,"std": 5.0}
        }
    },
    "parameters": {
        "model_steps": 100,
        "domains_file": "testDomains.csv",
        "request_timeout": 5,
        "request_lifetime": 10
    }
}
