--- MAUDE_HCS: maude_hcs
--- FTP TGEN V2 TEST
---
--- Tests the UM-V2 user model driving the FTP tgen actor
--- with the v2 two-level Markov model.
---

set show advisories off .

sload ./ftp-mamodel-v2.maude
sload ../../../common/maude/tgen-action-actor-v2.maude
sload ./ftpTgen-actor.maude
sload ./ftpServer-actor.maude

mod FTP-TGEN-V2-TEST is
  inc FTP-CONFIG-MAMODEL-V2 .
  inc USER-ACTION-ACTOR-V2 .
  inc FTP-TGEN .
  inc FTP-SERVER .

  --- Global constants
  --- The user model database: map model name to MAModel-v2
  eq MAModelMap = ("ftp" |-> ftp-config-ma-v2) .

  --- Override default model timeout — the FTP idle states
  --- have ~300s mean sleep, so the default 1000s is too low.
  eq defaultModelTimeOut = 100000.0 .

  --- Override model steps for testing (100 vs 100000 in config)
  eq defaultModelSteps = 100 .

  --- Minimal delay and noise for testing
  eq defaultDelay = 0.001 .
  eq noiseMax(msg:Msg) = 0.00001 .

  --- Actor addresses
  ops ftpUMAddr ftpTGAddr ftpSrvAddr : -> Address .

  --- FTP Tgen Actor: connects to the FTP server
  op ftpTGenA : -> Actor .
  eq ftpTGenA = mkFtpTgenA(ftpTGAddr, ftpSrvAddr, 5.0, 2) .

  --- FTP Server Actor
  op ftpSrvA : -> Actor .
  eq ftpSrvA = mkFtpServerA(ftpSrvAddr) .

  --- UM-V2 Actor: drives the FTP tgen with Markov model
  --- Sends:  (to ftpTGAddr from ftpUMAddr : actionQ(actionSpec))
  --- Receives: (to ftpUMAddr from ftpTGAddr : actionR("ok"))
  op umAct : -> Actor .
  eq umAct = mkTgenUMV2Actor(ftpUMAddr, "ftp", ftpTGAddr) .

  --- Initial configuration
  op iS : Nat -> Config .
  eq iS(j:Nat) =
    rCtr(j:Nat)
    umAct
    ftpTGenA
    ftpSrvA
    --- Kickoff: trigger the UM-V2 to start executing
    [0.1, to ftpUMAddr from ftpUMAddr : burstDelayTO, 0]
    .

  --- Initial config for rewriting
  op initConfig : -> Config .
  eq initConfig = run({0.0 | nil} iS(1), 100000.0) .

endm

set print attribute on .

eof

--- Basic test: run for 100000 time units
rew [2000] run({0.0 | nil} iS(1), 100000.0) .

