vars Min Max : Float .
vars j j1 n : Nat .
vars fl : Float .
vars jvl jvl1 : JVL .

  op genRandX : Nat Float Float -> [Float] .
  eq genRandX(j,Min, Max) = Min +
      (float(random(j) / 4294967296) * (Max  + (- Min)))  .
 
op testRand : Nat -> Bool .
eq testRand(0) = true .
ceq testRand(s j) = testRand(j) 
if fl := genRandX(j,0.,1.)
[print "ix " j " choice " fl]
.

op testR : Nat Nat Nat -> Nat .
eq testR(j,j,n) = n .
ceq testR(j, s j1,n) =
 testR(j, j1, if (fl < .5) then s n else n fi)
if j1 >= j
/\ fl := genRandX(j1,0.,1.)
.
eq testR(j,j1,n) = 0  [owise] .


