eq sLMM = ("download" |-> jl(js("wait_download")), "media" |-> jl(js("wait_media")), "wait_download" |-> jl(js("download") ; js("media")), "wait_media" |-> jl(js("download") ; js("media"))) .
    
eq wLMM = ("download" |-> jl(jf( 1.0)), "media" |-> jl(jf(1.0)), "wait_download" |-> jl(jf(5.0e-1) ; jf(1.0)), "wait_media" |-> jl(jf(5.0e-1) ; jf(1.0))) .
 
