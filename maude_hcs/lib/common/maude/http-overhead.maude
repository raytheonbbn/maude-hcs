makeHttpRequest(getRequest, makeTag("purple"))
.

eq req3-tg =
to X(mastodon-proxy) from tgen-mas-3-UM-client : makeHttpRequest(getRequest,    url("randimage:I-4-45252-3000.com"))
.

    
---------- response msgs
ops rsp0-tg rsp1-tg rsp2-tg rsp3-tg : -> Msg .
ops rsp0-rb rsp1-rb rsp2-rb rsp3-rb : -> Msg .

eq rsp0-tg =
