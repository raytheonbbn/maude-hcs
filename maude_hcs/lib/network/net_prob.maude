sload ./_net_aux.maude
sload ./tcp.maude
sload ../common/maude/cp2-interfaces.maude

mod NETWORK_CONNECTION is
  pr CP2-COMMON .
  pr NETWORK_NODE .
  pr TCP_NODE .
  pr TCP_SOCKET .

  vars channelClientAddr channelServerAddr netAddr netClientAddr netServerAddr remoteAddr LOCAL_ADDR REMOTE_ADDR : Address .
  vars flowAttrs netAttrs netAttrsNext netAttrsTrans logAttrs logAttrsNext pktAttrs : AttributeSet .
  vars CURRENT_CONNECTION : AttributeSet .
  vars content : Content .
  vars T : Float .
  vars msg : Msg .
  vars j jNext n : Nat .

  ****************************************************************************
  **** Network Client Rules
  ****************************************************************************
  crl [net-client-req]:
  rCtr(j)
  < netAddr : NetClient | (netAttrs,
                           remoteChannelAddr: REMOTE_ADDR,
                           localIfaceAddr: LOCAL_ADDR) >
****  < log : Log | logAttrs >
    {T, (to tcp(REMOTE_ADDR) from LOCAL_ADDR : content)}
  =>
  rCtr(jNext)
  < netAddr : NetClient | netAttrsNext >
****  < log : Log | logAttrsNext >
    [delay:Float, msg, 0]
  if netAttrsTrans := (netAttrs, remoteChannelAddr: REMOTE_ADDR, localIfaceAddr: LOCAL_ADDR)
    /\ {netAttrsNext , flowAttrs} := getFlowInfo(netAttrsTrans, (to netAddr from getLocalIfaceAddr(netAttrsTrans) : content))
    /\ netServerAddr := getRemoteEndpointAddr(netAttrs)
    /\ (pktAttrs, nextJ: jNext) := getSegmentDistribution(j, netServerAddr, netAddr, content, flowAttrs)
****      /\ lattrsNext := addPackets(lattrs, T, pattrs)
    /\ delay:Float := msgDelay(pktAttrs)
    /\ msg := (to REMOTE_ADDR from LOCAL_ADDR : content 
                                              :: flowAttrs)
    [ print "(" T ") Net client " netAddr " handling request, sending " msg "." ]
  .

  rl [net-client-resp]:
  < netAddr : NetClient | (netAttrs,
                           remoteChannelAddr: REMOTE_ADDR,
                           localIfaceAddr: LOCAL_ADDR) >
    {T, (to LOCAL_ADDR from REMOTE_ADDR : content :: flowAttrs)}
  =>
  < netAddr : NetClient | (netAttrs,
                           remoteChannelAddr: REMOTE_ADDR,
                           localIfaceAddr: LOCAL_ADDR) >
    [0., (to LOCAL_ADDR from REMOTE_ADDR : content), 0]
  [ print "(" T ") Net client " netAddr " handling response from " REMOTE_ADDR ", decapsulating transport." ]
  .

  ****************************************************************************
  **** Network Server Rules
  ****************************************************************************
  rl [net-server-req]:
  < netAddr : NetServer | (netAttrs,
                           localIfaceAddr: LOCAL_ADDR,
                           currentConnection: CURRENT_CONNECTION) >
****  < log : Log | lattrs >
    {T, (to LOCAL_ADDR from remoteAddr : content :: flowAttrs)}
  =>
  < netAddr : NetServer | (netAttrs,
                           localIfaceAddr: LOCAL_ADDR,
                           currentConnection: flowAttrs) >
****  < log : Log | lattrs1 >
  [0., (to LOCAL_ADDR from remoteAddr : content), 0]
  [ print "(" T ") Net client " netAddr " handling request to destination " LOCAL_ADDR ", decapsulating transport." ]
  .

  crl [net-server-resp]:
  rCtr(j)
  < netAddr : NetServer | (netAttrs, localIfaceAddr: LOCAL_ADDR) >
****  < log : Log | lattrs >
    {T, (to tcp(REMOTE_ADDR) from LOCAL_ADDR : content)}
  =>
  rCtr(jNext)
  < netAddr : NetServer | netAttrsTrans >
****  < log : Log | lattrs1 >
    [delay:Float, msg, 0]
  if netAttrsTrans := (netAttrs, localIfaceAddr: LOCAL_ADDR)
    /\ flowAttrs := getCurrentConnection(netAttrsTrans)
    /\ netClientAddr := getRemoteEndpointAddr(netAttrsTrans)
    /\ (pktAttrs, nextJ: jNext) := getSegmentDistribution(j, netClientAddr, netAddr, content, flowAttrs)
****      /\ logAttrsNext := addPackets(logAttrs, T, pktAttrs) >
    /\ delay:Float := msgDelay(pktAttrs)
    /\ msg := (to REMOTE_ADDR from LOCAL_ADDR : content :: flowAttrs)
    [ print "(" T ") Net server " netAddr " handling response, sending " msg "." ]
  .

endm
