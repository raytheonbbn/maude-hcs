set show advisories off .

sload ../../../deps/dns_formalization/Maude/common/actor.maude
sload ../../common/maude/byteseq
sload ../../common/maude/sampler-x
sload ../../common/maude/cp2-interfaces
sload ../../irc/_irc_aux

mod IRC-RBBYTESEQ-INTERFACE is
  inc ACTOR-MODEL .
  inc BYTESEQ .
  inc CP2-COMMON .
  inc SAMPLER-X .
  inc IRC_AUX  .
  

vars j : Nat .
vars attrs : AttributeSet .
vars ifAddr ircAddr rbSAddr rbRAddr ircEndp : Address .
vars msg : Msg .
vars ircMsg : IrcMsg .
vars byteseq : ByteSeq .
vars T : Float .

op ircToByteseq : IrcMsg -> ByteSeq [ctor] .
op ircFromByteseq : ByteSeq -> IrcMsg .
eq ircFromByteseq(ircToByteseq(ircMsg)) = ircMsg .

**** op getSize : Content -> Nat .
eq getSize(ircToByteseq(ircMsg)) = getSize(ircMsg) .
eq nbytes(ircToByteseq(ircMsg)) = getSize(ircMsg) .

op IrcByteSeqIface : -> ActorType .
op rbSndr:_  : Address -> Attribute [ctor] .
op rbRcvr:_  : Address -> Attribute [ctor] .
op ircEndp:_ : Address -> Attribute [ctor] .

op mkIrcByteSeqIface : Address Address Address Address 
                   -> Actor .
eq mkIrcByteSeqIface(ifAddr,ircAddr,rbSAddr,rbRAddr)
   =
   < ifAddr : IrcByteSeqIface | 
      ircEndp: ircAddr,
      rbSndr: rbSAddr,
      rbRcvr: rbRAddr >
  .

crl [fromIrc2rbS]:
  rCtr(j)
  {T, (to ifAddr from ircAddr : ircMsg)}
  < ifAddr : IrcByteSeqIface | 
     ircEndp: ircAddr, rbSndr: rbSAddr, rbRcvr: rbRAddr,
     attrs >
 =>
  rCtr(s j)
  < ifAddr : IrcByteSeqIface | 
     ircEndp: ircAddr, rbSndr: rbSAddr, rbRcvr: rbRAddr,
     attrs >
 [genRandomX(j,0.0, 0.0001) , msg,0]
 if msg := (to rbSAddr from ifAddr :
             ircToByteseq(ircMsg))
[print "(" T ") " "IrcIface " ifAddr " Rb from Irc " ircMsg ]  
.

crl [fromRbs2Irc]:
  rCtr(j)
  {T, (to ifAddr from rbRAddr : byteseq)}
  < ifAddr : IrcByteSeqIface | 
     ircEndp: ircAddr, rbSndr: rbSAddr, rbRcvr: rbRAddr,
     attrs >
 =>
  rCtr(s j)
  < ifAddr : IrcByteSeqIface | 
     ircEndp: ircAddr, rbSndr: rbSAddr, rbRcvr: rbRAddr,
     attrs >
 [genRandomX(j,0.0, 0.0001) , msg,0]
 if msg := (to ircAddr from ifAddr :
             ircFromByteseq(byteseq))
[print "(" T ") " "IrcIface " ifAddr " Irc from Rb " byteseq ]  .

endm


mod TEST-IRC-RBMAS-INTERFACE is
  inc IRC-RBBYTESEQ-INTERFACE .
  
ops ifAd ircAd rbSAd rbRAd : -> Address .
op ircByteSeqIfAct : -> Actor .
eq ircByteSeqIfAct =
       mkIrcByteSeqIface(ifAd,ircAd,rbSAd,rbRAd) .

op ircM : -> IrcMsg .

endm  
eof

rew ircByteSeqIfAct rCtr(9) {1.0,(to ifAd from ircAd : ircM)} .

rew ircByteSeqIfAct rCtr(10) {1.1,(to ifAd from rbRAd : ircToByteseq(ircM))} .