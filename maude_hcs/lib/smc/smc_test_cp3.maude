sload ../common/maude/adversary-observer
sload ../app/maude/probabilistic
sload ../../deps/dns_formalization/Maude/test/probabilistic-model/test_helpers
sload ../irc/irc_monitor 

mod HCS_TEST is
  inc DNS .
  inc USER-ACTION-ACTOR .
  inc DNS-TGEN .
  inc DNS-MAMODEL .
  inc MASTODON .
  inc MAS-TGEN .
  inc IODINE_DNS . --- + TEST-HELPERS .
  inc CP2_APP .
  inc ROUTER .
  inc ADVERSARY-OBSERVER .
  inc IRC_MONITOR .

  ops aliceIrcClientAddr bobIrcClientAddr ircServerAddr ircMonitorAddr : -> Address .

  op myMon : -> Actor .
  eq myMon = < ircMonitorAddr : IrcMonitor |
  msgSent: (
    messageTimestamp(2.25, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517656) ; 
    messageTimestamp(2.45, ircServerAddr, bobIrcClientAddr, 128, makeIrcChannelName("bbn"), 322655651935342083498517656) ; 
    messageTimestamp(5.75, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517657) ; 
    messageTimestamp(7.75, ircServerAddr, bobIrcClientAddr, 128, makeIrcChannelName("bbn"), 322655651935342083498517657) ; 
    messageTimestamp(1.115e+1, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName( "bbn"), 322655651935342083498517658) ; 
    messageTimestamp(1.515e+1, ircServerAddr, bobIrcClientAddr, 128, makeIrcChannelName("bbn"), 322655651935342083498517658)),
  msgRcvd: (
    messageTimestamp(2.35, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517656) ; 
    messageTimestamp(2.55, ircServerAddr, bobIrcClientAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517656) ; 
    messageTimestamp(6.75, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517657) ; 
    messageTimestamp(8.75, ircServerAddr, bobIrcClientAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517657) ; 
    messageTimestamp(1.315e+1, aliceIrcClientAddr, ircServerAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517658) ; 
    messageTimestamp(1.715e+1, ircServerAddr, bobIrcClientAddr, 1, makeIrcChannelName("bbn"), 322655651935342083498517658))
    > 
  .

endm

load smc_cp3
set print attribute on .

red getSentMsgNum(myMon) .
red getLatencyDistributionWindow(myMon, 0.0, 5.0) .
red getLatencyDistributionWindow(myMon, 0.0, 8.0) .
red getLatencyDistributionWindow(myMon, 5.0, 8.0) .
red getLatencyDistributionWindow(myMon, 5.0, 10.0) .
red getLatencyDistributionWindow(myMon, 0.0, 10.0) .
red getLatencyDistributionWindow(myMon, 0.0, 100.0) .
