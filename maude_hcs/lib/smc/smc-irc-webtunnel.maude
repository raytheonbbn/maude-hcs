---
--- test_webtunnel_irc.maude
---
--- Scenario: 2 IRC clients (Alice and Bob) communicating with a single
--- IRC server, each via a webtunnel client actor.  A shared webtunnel
--- server proxy terminates both tunnels and bridges traffic to the server.
---
--- Topology:
---
---  .-----------.       .-----------.               .-----------.
---  | IrcClient1|------>| WtClient1 |=====HTTPS====>|           |--------.
---  |  (Alice)  |<------| (alice)   |<=============<|           |        |
---  `-----------'       `-----------'               |           |   .-----------.
---                                                  | WtProxy   |   | IrcServer |
---  .-----------.       .-----------.               |           |   `-----------'
---  | IrcClient2|------>| WtClient2 |=====HTTPS====>|           |        |
---  |  (Bob)    |<------| (bob)     |<=============<|           |<-------'
---  `-----------'       `-----------'               `-----------'
---
--- Timeline:
---   t=0.10  Alice's WtClient initiates tunnel setup
---   t=0.15  Bob's WtClient initiates tunnel setup
---   ~0.46   Tunnels established (link delay + WtConnectOverhead = 0.35s)
---   t=0.50  Alice joins channel #maude-test (sent after tunnels open)
---   t=0.55  Bob joins channel #maude-test
---   t=2.00  Alice sends first IRC message
---   t=4.00  Bob sends first IRC message
---   t=6.00  Alice sends second IRC message
---
--- To run: load this file in Maude, then execute:
---   red initConfig .
---

sload ../webtunnel/webtunnel_prob
sload ../irc/irc_prob.maude
sload ../irc/irc_monitor.maude
sload ../common/maude/cp2-interfaces.maude

set print attribute on .

mod HCS_TEST is
  pr IRC .
  pr IRC_MONITOR .
  pr WEBTUNNEL .
  pr IRC_NAMES .
  pr IRC-DISPATCHER-INTERFACE .

  ---------------------------------------------------
  --- Addresses
  ---------------------------------------------------

  --- IRC layer actors
  ops ircaAddr ircbAddr irccAddr : -> Address .  --- Alice, Bob
  ops ircSrvAddr ircMonitorAddr  : -> Address .  --- IRC server

  --- Translation interface actors
  ops client1IfaceAddr client2IfaceAddr : -> Address .
  ops server1IfaceAddr server2IfaceAddr : -> Address .

  --- Webtunnel layer actors
  ops wtClient1Addr wtClient2Addr : -> Address .   --- Alice-side, Bob-side
  ops wtProxy1Addr wtProxy2Addr   : -> Address .   --- shared proxy

  ---------------------------------------------------
  --- Link model parameters
  ---
  --- A simple constant-delay, no-drop link for clarity.
  --- Override these equations to add latency or packet loss.
  ---------------------------------------------------
  op LinkParams : -> AttributeSet .
  eq LinkParams =
    (delayStd:    0.),
    (delayType:   "Constant"),
    (delayMean:   0.),
    (delayConst:  0.010),     --- 10 ms one-way delay
    (noiseMin:    0.),
    (noiseMax:    0.00001),
    (dropP:       0.),
    (canDrop:     false)
  .

  eq LinkData =
    --- Webtunnel clients <-> proxy
    aaa(wtClient1Addr, wtProxy1Addr,  LinkParams)
    aaa(wtProxy1Addr,  wtClient1Addr, LinkParams)
    aaa(wtClient2Addr, wtProxy2Addr,  LinkParams)
    aaa(wtProxy2Addr,  wtClient2Addr, LinkParams)
    --- Proxy <-> IRC server (local / low latency)
****    aaa(wtProxy1Addr,   ircSrvAddr,  LinkParams)
****    aaa(ircSrvAddr, wtProxyAddr,    LinkParams)
  .

  ---------------------------------------------------
  --- Message schedules
  ---
  --- imd(delaySeconds, room, messageSize)
  --- The delay is relative to the first scheduled send (set via ircMsgSendTime).
  --- Message text is generated by genIrcText(userId, counter, size).
  ---------------------------------------------------
  op aliceMessages : -> IrcMsgDelayList .
  eq aliceMessages =
        imd(0.000, "#room1", 289) ::
        imd(8.278, "#room1", 380) ::
        imd(19.992, "#room1", 282) ::
        imd(29.485, "#room1", 358) ::
        imd(40.801, "#room2", 151) ::
        imd(49.595, "#room1", 241) ::
        imd(61.541, "#room2", 121) ::
        imd(71.305, "#room1", 355) ::
        imd(79.889, "#room2", 323) ::
        imd(89.784, "#room1", 121) ::
        imd(100.969, "#room2", 390) ::
        imd(109.505, "#room2", 133) ::
        imd(117.833, "#room1", 227)
  .

  op bobMessages : -> IrcMsgDelayList .
  eq bobMessages =
        imd(0.000, "#room1", 278) ::
        imd(8.989, "#room1", 257) ::
        imd(20.500, "#room2", 330) ::
        imd(28.786, "#room2", 387) ::
        imd(38.913, "#room1", 170) ::
        imd(48.484, "#room2", 162) ::
        imd(58.978, "#room1", 126) ::
        imd(68.549, "#room1", 110) ::
        imd(78.635, "#room2", 163) ::
        imd(88.072, "#room2", 356) ::
        imd(98.174, "#room2", 205) ::
        imd(110.104, "#room2", 398) ::
        imd(119.482, "#room1", 380)    
  .

  ---------------------------------------------------
  --- Actors
  ---------------------------------------------------

  ops irca ircb ircServer : -> Actor .
  ops client1Iface client2Iface       : -> Actor .
  ops server1Iface server2Iface       : -> Actor .
  ops wtClient1 wtClient2             : -> Actor .
  ops wtProxy1 wtProxy2               : -> Actor .

  --- IRC clients.  Their raceboatAddr points to the WtClient actor,
  --- which acts as the transparent next-hop toward the IRC server.
  eq irca =
    mkIrcClient(ircaAddr,
                client1IfaceAddr,     --- raceboatAddr = WtClient (not server directly)
                "alice",
                aliceMessages)
  .

  eq ircb =
    mkIrcClient(ircbAddr,
                client2IfaceAddr,     --- raceboatAddr = WtClient
                "bob",
                bobMessages)
  .

  --- Translation interfaces.
  eq client1Iface = mkIrcByteSeqIface(client1IfaceAddr,
                                      ircaAddr,
                                      wtClient1Addr,
                                      wtClient1Addr)
  .
  eq client2Iface = mkIrcByteSeqIface(client2IfaceAddr,
                                      ircbAddr,
                                      wtClient2Addr,
                                      wtClient2Addr)
  .
  eq server1Iface = mkIrcByteSeqIface(server1IfaceAddr,
                                      ircSrvAddr,
                                      wtProxy1Addr,
                                      wtProxy1Addr)
  .
  eq server2Iface = mkIrcByteSeqIface(server2IfaceAddr,
                                      ircSrvAddr,
                                      wtProxy2Addr,
                                      wtProxy2Addr)
  .

  --- Webtunnel client actors.
  --- tlsServerName and upgradePath would be the bridge's public domain
  --- and secret path in a real deployment.
  eq wtClient1 =
    makeWtClient(wtClient1Addr,
                 wtProxy1Addr,
                 ircSrvAddr,
                 "irc.example.com",   --- TLS SNI
                 "secret/path/v1")    --- HTTP Upgrade path
  .

  eq wtClient2 =
    makeWtClient(wtClient2Addr,
                 wtProxy2Addr,
                 ircSrvAddr,
                 "irc.example.com",
                 "secret/path/v1")
  .

  --- Shared webtunnel server proxy.
  --- Its raceboatAddr (used by the IRC server for outbound messages) is
  --- wtProxyAddr itself, since the proxy terminates all tunnel connections.
  eq wtProxy1 =
    makeWtServerProxy(wtProxy1Addr, server1IfaceAddr)
  .

  eq wtProxy2 =
    makeWtServerProxy(wtProxy2Addr, server2IfaceAddr)
  .

  --- IRC server.  raceboatAddr = wtProxyAddr so all server-originated
  --- messages are delivered to the proxy, which routes them into tunnels.
  eq ircServer =
    mkIrcServer(ircSrvAddr)
  .

  ---------------------------------------------------
  --- Initial configuration
  ---------------------------------------------------

  op initState : -> Config .
  eq initState =
    rCtr(0)

    --- Actors
    irca
    ircb
    client1Iface
    client2Iface
    wtClient1
    wtClient2
    server1Iface
    server2Iface
    wtProxy1
    wtProxy2
    ircServer
    mkIrcMonitor(ircMonitorAddr,
                 (ircaAddr ;; ircbAddr ;; ircSrvAddr),
                 (ircaAddr ;; ircbAddr),
                 (rm("#room1", ircaAddr ;; ircbAddr) rm("#room2", ircaAddr ;; ircbAddr)))

    --- Phase 1: Tunnel setup
    --- Alice's WtClient initiates its tunnel.
    [0.10, (to wtClient1Addr from wtClient1Addr : WtStartCmd), 0]
    --- Bob's WtClient initiates its tunnel.
    [0.15, (to wtClient2Addr from wtClient2Addr : WtStartCmd), 0]

    --- Phase 2: Channel join (sent after tunnels should be open).
    --- These go to the WtClient, which wraps them in WtData and forwards.
    --- t=0.50 > 0.15 + 0.050 (link) + 0.35 (WtConnectOverhead) = 0.55
    --- (Using 0.65 to be safely after both tunnels are up.)
    [0.65, (to client1IfaceAddr from ircaAddr
             : JoinChannel(makeIrcChannelName("#room1"), ircaAddr)), 0]
    [0.70, (to client1IfaceAddr from ircaAddr
             : JoinChannel(makeIrcChannelName("#room2"), ircaAddr)), 0]
    [1.70, (to client2IfaceAddr from ircbAddr
             : JoinChannel(makeIrcChannelName("#room1"), ircbAddr)), 0]
    [1.75, (to client2IfaceAddr from ircbAddr
             : JoinChannel(makeIrcChannelName("#room2"), ircbAddr)), 0]

    --- Phase 3: IRC message send timers.
    --- ircMsgSendTime is the internal trigger used by the IRC actor's
    --- message-schedule machinery (from irc_prob.maude).
    [2.00, (to ircaAddr from ircaAddr : ircMsgSendTime), 0]
    [4.00, (to ircbAddr from ircbAddr : ircMsgSendTime), 0]
  .

  ---------------------------------------------------
  --- Run parameters
  ---------------------------------------------------
  op slimit : -> Float .
  eq slimit = 200.0 .    --- simulate 200 simulated seconds

  op initConfig : -> Config .
  eq initConfig = run({0.0 | nil} initState, slimit) .

endm
set print attribute on .
rew initConfig .
eof
