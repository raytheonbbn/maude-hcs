{
    "markov": {
        "media": {
            "wait_media": 1.0
        },
        "download": {
            "wait_download": 1.0
        },
        "wait_media": {
            "download": 1.0
        },
        "wait_download": {
            "media": 1.0
        }
    },
    "actions": {
        "media": {
            "type": "media",
            "linkId": "mastodonCompositionReactiveFile/mastodonCompositionReactiveFile/LinkID_1",
            "contentType": "image",
            "numImages": {
                "random": "uniform",
                "min": 1,
                "max": 4
            },
            "start": true
        },
        "wait_media": {
            "type": "wait",
            "sleep": {
                "random": "gaussian",
                "mean": 10.0,
                "std": 2.0,
                "floor": 5.5
            }
        },
        "download": {
            "type": "download",
            "linkId": "mastodonCompositionReactiveFile/mastodonCompositionReactiveFile/LinkID_0"
        },
        "wait_download": {
            "type": "wait",
            "sleep": {
                "random": "gaussian",
                "mean": 8.0,
                "std": 1.0
            }
        }
    },
    "parameters": {
        "model_steps": 1000
    }
}