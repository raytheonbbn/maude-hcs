{
    "markov": {
        "download": {"wait_download": 1.0},
        "media":  {"wait_media": 1.0},
        "wait_media": {"download": 1.0},
        "wait_download": {"media": 1.0}
    },
    "actions": {
        "download": {
            "type": "download",
            "linkId": "mastodonCompositionReactiveFile/mastodonCompositionReactiveFile/LinkID_0",
            "start": true
        },
        "wait_download": {
            "type": "wait",
            "sleep": {"random": "gaussian","mean": 8.0,"std": 1.0}
        },
        "media": {
            "type": "media",
            "linkId": "mastodonCompositionReactiveFile/mastodonCompositionReactiveFile/LinkID_1",
            "contentType": "image",
            "numImages": {"random": "uniform", "min": 1 ,"max": 4}
        },
        "wait_media": {
            "type": "wait",
            "sleep": {"random": "gaussian", "mean": 10.0, "std": 2.0, "floor": 5.5}
        }

    },
    "parameters": {
        "model_steps": 1000
    }
}
